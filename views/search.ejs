<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LeadMapper — Google Maps Lead Gen</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    .sidebar { background: #1a1f1e; }
    .sidebar a.active { background: #4a7c59; }
    .sidebar a:hover { background: #2a352e; }
    .detail-panel { transform: translateX(100%); transition: transform 0.3s ease; }
    .detail-panel.open { transform: translateX(0); }
    .spinner { border: 3px solid #e5e7eb; border-top-color: #4a7c59; border-radius: 50%; width: 20px; height: 20px; animation: spin 0.8s linear infinite; display: inline-block; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .bookmark-btn.saved svg { fill: #4a7c59; color: #4a7c59; }
  </style>
</head>
<body class="bg-gray-50 text-gray-800">
  <div class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <nav class="sidebar w-16 lg:w-56 flex-shrink-0 flex flex-col items-center lg:items-stretch py-4 text-white">
      <div class="flex items-center gap-2 px-4 mb-8">
        <svg class="w-7 h-7 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <span class="hidden lg:block font-bold text-lg">LeadMapper</span>
      </div>
      <a href="/" class="flex items-center gap-3 px-4 py-2.5 rounded-lg mx-2 mb-1 text-sm active">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <span class="hidden lg:block">Search</span>
      </a>
      <a href="/history" class="flex items-center gap-3 px-4 py-2.5 rounded-lg mx-2 mb-1 text-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span class="hidden lg:block">History</span>
      </a>
      <a href="/leads" class="flex items-center gap-3 px-4 py-2.5 rounded-lg mx-2 mb-1 text-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
        <span class="hidden lg:block">Leads</span>
      </a>
    </nav>

    <!-- Main content -->
    <main class="flex-1 overflow-y-auto">
      <!-- Filter bar -->
      <form method="POST" action="/search" id="searchForm" class="bg-white border-b px-6 py-4">
        <div class="flex flex-wrap items-end gap-3">
          <div class="flex-1 min-w-[160px]">
            <label class="block text-xs font-medium text-gray-500 mb-1">KEYWORD</label>
            <input type="text" name="keyword" placeholder="e.g. restaurant, dentist" value="<%= query?.keyword || '' %>" required
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-green-500 focus:border-transparent">
          </div>
          <div class="flex-1 min-w-[120px]">
            <label class="block text-xs font-medium text-gray-500 mb-1">CITY</label>
            <input type="text" name="city" placeholder="e.g. London" value="<%= query?.city || '' %>" required
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-green-500 focus:border-transparent">
          </div>
          <div class="flex-1 min-w-[120px]">
            <label class="block text-xs font-medium text-gray-500 mb-1">COUNTRY / STATE</label>
            <input type="text" name="state" placeholder="e.g. UK, California" value="<%= query?.state || '' %>" required
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-green-500 focus:border-transparent">
          </div>
          <div class="w-20">
            <label class="block text-xs font-medium text-gray-500 mb-1">RESULTS</label>
            <select name="maxResults" class="w-full border border-gray-300 rounded-lg px-2 py-2 text-sm">
              <option value="20" <%= query?.maxResults == 20 ? 'selected' : '' %>>20</option>
              <option value="50" <%= query?.maxResults == 50 ? 'selected' : '' %>>50</option>
              <option value="100" <%= query?.maxResults == 100 ? 'selected' : '' %>>100</option>
              <option value="250" <%= query?.maxResults == 250 ? 'selected' : '' %>>250</option>
              <option value="500" <%= query?.maxResults == 500 ? 'selected' : '' %>>500</option>
            </select>
          </div>
          <div class="w-20">
            <label class="block text-xs font-medium text-gray-500 mb-1">MIN ★</label>
            <input type="number" name="ratingMin" step="0.1" min="0" max="5" placeholder="e.g. 3.5" value="<%= query?.ratingMin || '' %>"
              class="w-full border border-gray-300 rounded-lg px-2 py-2 text-sm">
          </div>
          <div class="w-20">
            <label class="block text-xs font-medium text-gray-500 mb-1">MAX ★</label>
            <input type="number" name="ratingMax" step="0.1" min="0" max="5" placeholder="e.g. 4.5" value="<%= query?.ratingMax || '' %>"
              class="w-full border border-gray-300 rounded-lg px-2 py-2 text-sm">
          </div>
          <div class="w-28">
            <label class="block text-xs font-medium text-gray-500 mb-1">MAX REVIEWS</label>
            <select name="maxReviews" class="w-full border border-gray-300 rounded-lg px-2 py-2 text-sm">
              <option value="">Any</option>
              <option value="100" <%= query?.maxReviews == '100' ? 'selected' : '' %>>Under 100</option>
              <option value="200" <%= query?.maxReviews == '200' ? 'selected' : '' %>>Under 200</option>
              <option value="300" <%= query?.maxReviews == '300' ? 'selected' : '' %>>Under 300</option>
              <option value="500" <%= query?.maxReviews == '500' ? 'selected' : '' %>>Under 500</option>
              <option value="1000" <%= query?.maxReviews == '1000' ? 'selected' : '' %>>Under 1000</option>
            </select>
          </div>
          <div class="w-40">
            <label class="block text-xs font-medium text-gray-500 mb-1" title="Which contact channel gets tagged as the primary outreach method">OUTREACH PRIORITY</label>
            <select name="outreachPriority" class="w-full border border-gray-300 rounded-lg px-2 py-2 text-sm">
              <option value="phone-first" <%= (!query?.outreachPriority || query?.outreachPriority === 'phone-first') ? 'selected' : '' %>>Phone → Email → DM</option>
              <option value="dm-first" <%= query?.outreachPriority === 'dm-first' ? 'selected' : '' %>>DM → Phone → Email</option>
              <option value="email-first" <%= query?.outreachPriority === 'email-first' ? 'selected' : '' %>>Email → Phone → DM</option>
            </select>
          </div>
          <div class="flex items-center gap-2 self-end pb-1">
            <input type="checkbox" name="enrichContacts" id="enrichContacts" class="rounded text-green-700 focus:ring-green-500"
              <%= query?.enrichContacts === 'on' ? 'checked' : '' %>>
            <label for="enrichContacts" class="text-xs font-medium text-gray-500 cursor-pointer" title="Scans each business website for email addresses">FIND EMAILS</label>
          </div>
          <button type="submit" id="searchBtn"
            class="bg-green-700 hover:bg-green-800 text-white px-5 py-2 rounded-lg text-sm font-medium flex items-center gap-2 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <span id="btnText">Search</span>
          </button>
        </div>
      </form>

      <% if (error) { %>
        <div class="mx-6 mt-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"><%= error %></div>
      <% } %>

      <% if (results && results.length > 0) { %>
        <!-- Results header -->
        <div class="px-6 py-3 flex items-center justify-between">
          <div class="text-sm text-gray-500">
            Found <span class="font-semibold text-gray-800"><%= results.length %></span> results
            <% if (typeof totalScraped !== 'undefined' && totalScraped > 0 && totalScraped !== results.length) { %>
              <span class="text-gray-400">out of <%= totalScraped %> scraped</span>
            <% } %>
            <% if (query?.searchString) { %> for "<%= query.searchString %>"<% } %>
          </div>
          <div class="flex items-center gap-2">
            <select id="exportFilter" class="text-xs border border-gray-300 rounded-lg px-2 py-1.5">
              <option value="all">All Results</option>
              <option value="B">Seg B: Good Rating, Low Vol</option>
              <option value="C">Seg C: Low Rating</option>
              <option value="Call">Call List Only</option>
              <option value="Email">Email List Only</option>
              <option value="DM">DM List Only (Instagram)</option>
              <option value="B-Call">Seg B — Calls</option>
              <option value="B-Email">Seg B — Emails</option>
              <option value="C-Call">Seg C — Calls</option>
              <option value="C-Email">Seg C — Emails</option>
            </select>
            <button onclick="exportCSV()" class="text-sm bg-white border border-gray-300 hover:bg-gray-50 px-3 py-1.5 rounded-lg flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
              Export CSV
            </button>
          </div>
        </div>

        <!-- Segment summary -->
        <%
          const segB = results.filter(r => r.segmentCode === 'B');
          const segC = results.filter(r => r.segmentCode === 'C');
          const callList = results.filter(r => r.outreach === 'Call');
          const emailList = results.filter(r => r.outreach === 'Email');
          const dmList = results.filter(r => r.outreach === 'DM');
        %>
        <div class="px-6 pb-2 flex flex-wrap gap-2">
          <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700">B: Good Rating, Low Vol — <%= segB.length %></span>
          <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-red-50 text-red-700">C: Low Rating — <%= segC.length %></span>
          <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-green-50 text-green-700">Calls — <%= callList.length %></span>
          <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-purple-50 text-purple-700">Emails — <%= emailList.length %></span>
          <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-pink-50 text-pink-600">DMs — <%= dmList.length %></span>
        </div>

        <!-- Results table -->
        <div class="px-6">
          <div class="bg-white rounded-xl border overflow-hidden">
            <table class="w-full text-sm">
              <thead class="bg-gray-50 text-gray-500 text-xs uppercase">
                <tr>
                  <th class="px-4 py-3 text-left"><input type="checkbox" id="selectAll" class="rounded"></th>
                  <th class="px-4 py-3 text-left">Company</th>
                  <th class="px-4 py-3 text-left">Phone</th>
                  <th class="px-4 py-3 text-left">Email</th>
                  <th class="px-4 py-3 text-left">Instagram</th>
                  <th class="px-4 py-3 text-left">Website</th>
                  <th class="px-4 py-3 text-left">Location</th>
                  <th class="px-4 py-3 text-center">Rating</th>
                  <th class="px-4 py-3 text-center">Reviews</th>
                  <th class="px-4 py-3 text-center">Segment</th>
                  <th class="px-4 py-3 text-center">Outreach</th>
                  <th class="px-4 py-3 text-center">Save</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <% results.forEach((r, i) => { %>
                <tr class="hover:bg-gray-50 cursor-pointer result-row"
                    data-index="<%= i %>"
                    data-title="<%= r.title %>"
                    data-phone="<%= r.phone %>"
                    data-email="<%= r.email %>"
                    data-instagram="<%= r.instagram || '' %>"
                    data-website="<%= r.website %>"
                    data-category="<%= r.category %>"
                    data-address="<%= r.address %>"
                    data-rating="<%= r.rating %>"
                    data-reviews="<%= r.reviewCount %>"
                    data-segment="<%= r.segmentCode || '-' %>"
                    data-outreach="<%= r.outreach || 'None' %>"
                    data-url="<%= r.url %>">
                  <td class="px-4 py-3"><input type="checkbox" class="row-check rounded" onclick="event.stopPropagation()"></td>
                  <td class="px-4 py-3 font-medium text-gray-900"><%= r.title %></td>
                  <td class="px-4 py-3 text-gray-600"><%= r.phone || '—' %></td>
                  <td class="px-4 py-3">
                    <% if (r.email) { %>
                      <a href="mailto:<%= r.email %>" onclick="event.stopPropagation()" class="text-green-700 hover:underline truncate block max-w-[200px]"><%= r.email %></a>
                    <% } else { %><span class="text-gray-300">—</span><% } %>
                  </td>
                  <td class="px-4 py-3">
                    <% if (r.instagram) { %>
                      <a href="https://instagram.com/<%= r.instagram %>" target="_blank" onclick="event.stopPropagation()" class="text-pink-600 hover:underline truncate block max-w-[140px]">@<%= r.instagram %></a>
                    <% } else { %><span class="text-gray-300">—</span><% } %>
                  </td>
                  <td class="px-4 py-3">
                    <% if (r.website) { %>
                      <a href="<%= r.website %>" target="_blank" onclick="event.stopPropagation()" class="text-green-700 hover:underline truncate block max-w-[180px]"><%= r.website.replace(/https?:\/\/(www\.)?/, '').split('/')[0] %></a>
                    <% } else { %>—<% } %>
                  </td>
                  <td class="px-4 py-3 text-gray-600 truncate max-w-[200px]"><%= r.address || r.city %></td>
                  <td class="px-4 py-3 text-center">
                    <% if (r.rating !== null) { %>
                      <span class="inline-flex items-center gap-1 text-amber-600 font-medium">★ <%= r.rating %></span>
                    <% } else { %>—<% } %>
                  </td>
                  <td class="px-4 py-3 text-center text-gray-500"><%= r.reviewCount || 0 %></td>
                  <td class="px-4 py-3 text-center">
                    <% if (r.segmentCode === 'B') { %>
                      <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">B</span>
                    <% } else if (r.segmentCode === 'C') { %>
                      <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-red-50 text-red-700">C</span>
                    <% } else { %>
                      <span class="text-gray-300">—</span>
                    <% } %>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <% if (r.outreach === 'Call') { %>
                      <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700">Call</span>
                    <% } else if (r.outreach === 'Email') { %>
                      <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-purple-50 text-purple-700">Email</span>
                    <% } else if (r.outreach === 'DM') { %>
                      <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium bg-pink-50 text-pink-600">DM</span>
                    <% } else { %>
                      <span class="text-gray-300">—</span>
                    <% } %>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <button class="bookmark-btn p-1 rounded hover:bg-gray-100" onclick="event.stopPropagation(); toggleBookmark(this, <%= i %>)" data-title="<%= r.title %>">
                      <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
                    </button>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      <% } else if (results && results.length === 0) { %>
        <div class="flex flex-col items-center justify-center py-20 text-gray-400">
          <svg class="w-16 h-16 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <p class="text-lg font-medium text-gray-500">No results match your filters</p>
          <p class="text-sm mt-1">Try increasing the results count or widening your rating/review filters.</p>
        </div>
      <% } else if (!error) { %>
        <div class="flex flex-col items-center justify-center py-20 text-gray-400">
          <svg class="w-20 h-20 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <p class="text-lg font-medium text-gray-500">Find your next leads</p>
          <p class="text-sm mt-1">Enter a business type, city, and country above to start scraping Google Maps.</p>
        </div>
      <% } %>
    </main>

    <!-- Detail panel (slide-in from right) -->
    <div id="detailPanel" class="detail-panel fixed top-0 right-0 h-full w-96 bg-white shadow-2xl z-50 overflow-y-auto">
      <div class="p-6">
        <button onclick="closePanel()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>

        <div class="flex items-center gap-3 mb-6">
          <div id="panelAvatar" class="w-12 h-12 rounded-full bg-green-100 text-green-700 flex items-center justify-center text-xl font-bold"></div>
          <div>
            <h2 id="panelTitle" class="text-lg font-bold"></h2>
            <p id="panelCategory" class="text-sm text-gray-500"></p>
          </div>
        </div>

        <div id="panelRating" class="flex items-center gap-2 mb-6 text-amber-500 font-medium"></div>

        <div class="space-y-4 mb-6">
          <div id="panelPhoneRow" class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <a id="panelPhone" href="#" class="text-green-700 hover:underline"></a>
          </div>
          <div id="panelEmailRow" class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <span id="panelEmail" class="text-sm"></span>
          </div>
          <div id="panelInstagramRow" class="flex items-center gap-3">
            <svg class="w-5 h-5 text-pink-400 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            <a id="panelInstagram" href="#" target="_blank" class="text-pink-600 hover:underline text-sm"></a>
          </div>
          <div id="panelAddressRow" class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/></svg>
            <span id="panelAddress" class="text-sm text-gray-600"></span>
          </div>
        </div>

        <div class="space-y-2">
          <a id="panelWebsiteBtn" href="#" target="_blank" class="block w-full text-center bg-green-700 hover:bg-green-800 text-white py-2.5 rounded-lg text-sm font-medium transition">Visit Website</a>
          <a id="panelMapsBtn" href="#" target="_blank" class="block w-full text-center bg-gray-100 hover:bg-gray-200 text-gray-700 py-2.5 rounded-lg text-sm font-medium transition">Open in Google Maps</a>
          <button id="panelSaveBtn" onclick="saveLead()" class="w-full bg-white border-2 border-green-700 text-green-700 hover:bg-green-50 py-2.5 rounded-lg text-sm font-medium transition">Save Lead</button>
        </div>
      </div>
    </div>
    <div id="panelOverlay" class="fixed inset-0 bg-black/20 z-40 hidden" onclick="closePanel()"></div>
  </div>

  <script>
    // Store results for export and panel
    const allResults = <%- JSON.stringify(results || []) %>;
    let savedLeads = {};
    let currentLead = null;

    // Load saved leads on page load
    fetch('/leads/saved').then(r => r.json()).then(leads => {
      leads.forEach(l => { savedLeads[l.title] = l.key; });
      document.querySelectorAll('.bookmark-btn').forEach(btn => {
        if (savedLeads[btn.dataset.title]) {
          btn.classList.add('saved');
          btn.querySelector('svg').setAttribute('fill', '#4a7c59');
        }
      });
    });

    // Search form loading state
    document.getElementById('searchForm').addEventListener('submit', function() {
      const btn = document.getElementById('searchBtn');
      btn.disabled = true;
      btn.classList.add('opacity-60');
      const enrich = document.getElementById('enrichContacts').checked;
      document.getElementById('btnText').innerHTML = '<span class="spinner"></span> ' + (enrich ? 'Searching & finding emails...' : 'Searching...');
    });

    // Select all
    document.getElementById('selectAll')?.addEventListener('change', function() {
      document.querySelectorAll('.row-check').forEach(cb => cb.checked = this.checked);
    });

    // Row click -> detail panel
    document.querySelectorAll('.result-row').forEach(row => {
      row.addEventListener('click', () => openPanel(row.dataset));
    });

    function openPanel(data) {
      currentLead = data;
      document.getElementById('panelAvatar').textContent = data.title.charAt(0);
      document.getElementById('panelTitle').textContent = data.title;
      document.getElementById('panelCategory').textContent = data.category || '';

      const rating = data.rating && data.rating !== 'null' ? `★ ${data.rating}` : '';
      const reviews = data.reviews ? `(${data.reviews} reviews)` : '';
      document.getElementById('panelRating').textContent = `${rating} ${reviews}`;

      const phoneEl = document.getElementById('panelPhone');
      const phoneRow = document.getElementById('panelPhoneRow');
      if (data.phone) { phoneEl.textContent = data.phone; phoneEl.href = 'tel:' + data.phone; phoneRow.style.display = 'flex'; }
      else { phoneRow.style.display = 'none'; }

      const emailEl = document.getElementById('panelEmail');
      const emailRow = document.getElementById('panelEmailRow');
      if (data.email) { emailEl.textContent = data.email; emailRow.style.display = 'flex'; }
      else { emailRow.style.display = 'none'; }

      const igEl = document.getElementById('panelInstagram');
      const igRow = document.getElementById('panelInstagramRow');
      if (data.instagram) { igEl.textContent = '@' + data.instagram; igEl.href = 'https://instagram.com/' + data.instagram; igRow.style.display = 'flex'; }
      else { igRow.style.display = 'none'; }

      document.getElementById('panelAddress').textContent = data.address || '';
      document.getElementById('panelWebsiteBtn').href = data.website || '#';
      document.getElementById('panelWebsiteBtn').style.display = data.website ? 'block' : 'none';
      document.getElementById('panelMapsBtn').href = data.url || '#';
      document.getElementById('panelMapsBtn').style.display = data.url ? 'block' : 'none';

      // Update save button state
      const saveBtn = document.getElementById('panelSaveBtn');
      if (savedLeads[data.title]) {
        saveBtn.textContent = 'Saved ✓ — Click to Remove';
        saveBtn.classList.add('bg-green-50');
      } else {
        saveBtn.textContent = 'Save Lead';
        saveBtn.classList.remove('bg-green-50');
      }

      document.getElementById('detailPanel').classList.add('open');
      document.getElementById('panelOverlay').classList.remove('hidden');
    }

    function closePanel() {
      document.getElementById('detailPanel').classList.remove('open');
      document.getElementById('panelOverlay').classList.add('hidden');
      currentLead = null;
    }

    async function toggleBookmark(btn, index) {
      const title = btn.dataset.title;
      const lead = allResults[index];

      if (savedLeads[title]) {
        // Unsave
        await fetch(`/leads/delete/${savedLeads[title]}`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        delete savedLeads[title];
        btn.classList.remove('saved');
        btn.querySelector('svg').setAttribute('fill', 'none');
        // Sync panel if open
        if (currentLead?.title === title) {
          document.getElementById('panelSaveBtn').textContent = 'Save Lead';
          document.getElementById('panelSaveBtn').classList.remove('bg-green-50');
        }
      } else {
        // Save
        const res = await fetch('/leads/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(lead)
        });
        const data = await res.json();
        savedLeads[title] = data.key;
        btn.classList.add('saved');
        btn.querySelector('svg').setAttribute('fill', '#4a7c59');
        // Sync panel
        if (currentLead?.title === title) {
          document.getElementById('panelSaveBtn').textContent = 'Saved ✓ — Click to Remove';
          document.getElementById('panelSaveBtn').classList.add('bg-green-50');
        }
      }
    }

    async function saveLead() {
      if (!currentLead) return;
      const title = currentLead.title;
      const idx = parseInt(currentLead.index);
      const btn = document.getElementById('panelSaveBtn');
      const rowBtn = document.querySelector(`.bookmark-btn[data-title="${CSS.escape(title)}"]`);

      if (savedLeads[title]) {
        // Unsave
        await fetch(`/leads/delete/${savedLeads[title]}`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        delete savedLeads[title];
        btn.textContent = 'Save Lead';
        btn.classList.remove('bg-green-50');
        if (rowBtn) { rowBtn.classList.remove('saved'); rowBtn.querySelector('svg').setAttribute('fill', 'none'); }
      } else {
        const lead = allResults[idx];
        const res = await fetch('/leads/save', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(lead) });
        const data = await res.json();
        savedLeads[title] = data.key;
        btn.textContent = 'Saved ✓ — Click to Remove';
        btn.classList.add('bg-green-50');
        if (rowBtn) { rowBtn.classList.add('saved'); rowBtn.querySelector('svg').setAttribute('fill', '#4a7c59'); }
      }
    }

    function exportCSV() {
      const filter = document.getElementById('exportFilter').value;
      let data = allResults;
      let suffix = 'all';

      if (filter === 'B') { data = data.filter(r => r.segmentCode === 'B'); suffix = 'seg-B'; }
      else if (filter === 'C') { data = data.filter(r => r.segmentCode === 'C'); suffix = 'seg-C'; }
      else if (filter === 'Call') { data = data.filter(r => r.outreach === 'Call'); suffix = 'calls'; }
      else if (filter === 'Email') { data = data.filter(r => r.outreach === 'Email'); suffix = 'emails'; }
      else if (filter === 'DM') { data = data.filter(r => r.outreach === 'DM'); suffix = 'dms'; }
      else if (filter === 'B-Call') { data = data.filter(r => r.segmentCode === 'B' && r.outreach === 'Call'); suffix = 'seg-B-calls'; }
      else if (filter === 'B-Email') { data = data.filter(r => r.segmentCode === 'B' && r.outreach === 'Email'); suffix = 'seg-B-emails'; }
      else if (filter === 'C-Call') { data = data.filter(r => r.segmentCode === 'C' && r.outreach === 'Call'); suffix = 'seg-C-calls'; }
      else if (filter === 'C-Email') { data = data.filter(r => r.segmentCode === 'C' && r.outreach === 'Email'); suffix = 'seg-C-emails'; }

      if (data.length === 0) { alert('No results match this filter.'); return; }

      const headers = ['Name','Phone','Email','Instagram','Website','Category','Address','Rating','Reviews','Segment','Outreach','Google Maps URL'];
      const rows = data.map(r =>
        [r.title, r.phone, r.email, r.instagram || '', r.website, r.category, r.address, r.rating, r.reviewCount, r.segment || '', r.outreach || '', r.url]
        .map(v => `"${(v||'').toString().replace(/"/g,'""')}"`)
        .join(',')
      );
      const csv = [headers.join(','), ...rows].join('\n');
      const blob = new Blob([csv], { type: 'text/csv' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `leads-${suffix}.csv`;
      a.click();
    }
  </script>
</body>
</html>
