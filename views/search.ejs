<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LeadHunter</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      /* Core — red / black / white only */
      --red: #E11D2E;         /* Primary action red */
      --red-hover: #B8161E;   /* Primary action red hover */
      --red-active: #8B1015;  /* Primary action red pressed */
      --red-soft: #FEE2E2;    /* Red tint for backgrounds */
      --black: #0A0A0A;
      --white: #FFFFFF;
      --surface: #FAFAFA;
      --border: #EAEAEA;
      --border-strong: #D4D4D4;
      --text-primary: #0A0A0A;
      --text-secondary: #6B6B6B;
      --text-tertiary: #9A9A9A;
      /* Legacy tokens kept for minimal-diff compatibility; all mapped to the new palette */
      --near-black: var(--text-primary);
      --body: var(--text-primary);
      --muted: var(--text-secondary);
      --section: var(--surface);
      --indigo: var(--red);            /* Any lingering "indigo" accent becomes red */
      --indigo-hover: var(--red-hover);
      --lavender: var(--surface);      /* Soft backgrounds become neutral */
      --pink: var(--black);            /* Instagram badge background = black */
      --pink-soft: var(--black);
      --sky: var(--text-primary);      /* Phone badge text */
      --sky-soft: var(--white);        /* Phone badge background */
      --teal: var(--white);            /* Email badge text */
      --teal-soft: var(--red);         /* Email badge background */
      /* Semantic — use sparingly */
      --success: #0F7A3E;              /* Used only for "copied" toasts */
      --warn: #B45309;                 /* Warning banners */
      --warn-soft: #FEF3C7;
      --amber: #B45309;
      /* Sizing / motion */
      --radius-card: 8px; --radius-icon: 8px; --radius-input: 6px; --radius-pill: 9999px;
      --shadow-soft: 0 1px 2px rgba(10, 10, 10, 0.04);
      --shadow-cta: 0 2px 6px rgba(225, 29, 46, 0.18);
      --shadow-float: 0 12px 32px rgba(10, 10, 10, 0.12);
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body { font-family: 'Inter', -apple-system, sans-serif; background: var(--section); color: var(--body); font-size: 14px; line-height: 1.5; -webkit-font-smoothing: antialiased; }
    h1, h2, h3 { color: var(--near-black); margin: 0; font-weight: 700; letter-spacing: -0.01em; }
    p { margin: 0; }
    a { color: var(--indigo); text-decoration: none; }
    a:hover { color: var(--indigo-hover); }

    .ui-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); }
    .section-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-secondary); margin-bottom: 12px; display: block; }
    .caption { font-size: 12px; color: var(--muted); line-height: 1.4; }
    .helper-text { font-size: 12px; color: var(--muted); margin-top: 6px; line-height: 1.4; }

    .input, .select { font-family: inherit; font-size: 14px; padding: 10px 12px; background: var(--white); border: 1px solid var(--border); border-radius: var(--radius-input); color: var(--near-black); width: 100%; transition: border-color 0.15s, box-shadow 0.15s; }
    .input:focus, .select:focus { outline: none; border-color: var(--red); box-shadow: 0 0 0 3px rgba(225, 29, 46, 0.15); }
    .input::placeholder { color: #9897A6; }
    select.select { appearance: none; background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 20 20' fill='%236B6B80'%3e%3cpath fill-rule='evenodd' d='M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z' clip-rule='evenodd'/%3e%3c/svg%3e"); background-repeat: no-repeat; background-position: right 10px center; background-size: 14px; padding-right: 32px; cursor: pointer; }

    .btn { font-family: inherit; font-size: 14px; font-weight: 500; padding: 10px 16px; border-radius: var(--radius-input); border: 1px solid var(--border); background: var(--white); color: var(--near-black); cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 6px; transition: background 0.15s, border-color 0.15s, color 0.15s; }
    .btn:hover { background: var(--section); border-color: var(--border-strong); }
    .btn-primary { background: var(--red); border: 1px solid var(--red); color: var(--white); padding: 10px 22px; border-radius: var(--radius-input); font-weight: 500; font-size: 14px; box-shadow: none; }
    .btn-primary:hover { background: var(--red-hover); border-color: var(--red-hover); }
    .btn-primary:active { background: var(--red-active); border-color: var(--red-active); }
    .btn-primary:disabled { opacity: 0.65; cursor: not-allowed; }
    .btn-ghost { background: transparent; border-color: transparent; color: var(--muted); }
    .btn-ghost:hover { background: var(--section); color: var(--near-black); }

    .card { background: var(--white); border: 1px solid var(--border); border-radius: var(--radius-card); box-shadow: var(--shadow-soft); }

    .sidebar { background: var(--white); border-right: 1px solid var(--border); width: 236px; flex-shrink: 0; display: flex; flex-direction: column; height: 100vh; position: sticky; top: 0; }
    .brand-lockup { display: flex; align-items: center; gap: 8px; padding: 22px 20px 18px; border-bottom: 1px solid var(--border); }
    .logo-mark { color: var(--black); flex-shrink: 0; }
    .logo-wordmark { font-family: 'Inter', sans-serif; font-weight: 600; font-size: 18px; color: var(--black); letter-spacing: -0.01em; }
    .sidebar-nav { padding: 12px 8px; flex: 1; }
    .sidebar-nav a { display: flex; align-items: center; gap: 10px; padding: 9px 12px; margin: 2px 0; border-radius: var(--radius-input); font-size: 14px; font-weight: 500; color: var(--text-secondary); text-decoration: none; position: relative; }
    .sidebar-nav a:hover { background: var(--surface); color: var(--text-primary); }
    .sidebar-nav a.active { background: var(--surface); color: var(--text-primary); }
    .sidebar-nav a.active::before { content: ''; position: absolute; left: -8px; top: 8px; bottom: 8px; width: 3px; background: var(--red); border-radius: 2px; }
    /* Recent searches disclosure */
    .sidebar-recent { margin-top: 18px; padding: 0 8px; }
    .sidebar-recent summary { list-style: none; cursor: pointer; font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-tertiary); padding: 4px 8px; user-select: none; }
    .sidebar-recent summary::-webkit-details-marker { display: none; }
    .sidebar-recent a.recent-item { display: flex; flex-direction: column; gap: 2px; padding: 7px 10px; margin: 1px 0; border-radius: var(--radius-input); color: var(--text-secondary); font-size: 13px; font-weight: 500; text-decoration: none; }
    .sidebar-recent a.recent-item:hover { background: var(--surface); color: var(--text-primary); }
    .sidebar-recent .recent-title { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sidebar-recent .recent-meta { font-size: 11px; color: var(--text-tertiary); font-weight: 400; }
    .sidebar-nav a svg { width: 18px; height: 18px; flex-shrink: 0; }
    .sidebar-footer { padding: 16px; border-top: 1px solid var(--border); }
    .credit-indicator { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 500; color: var(--muted); padding: 5px 10px; background: var(--section); border-radius: var(--radius-pill); }
    .credit-indicator .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--indigo); flex-shrink: 0; }

    /* ——— Info tooltip (reusable) ——— */
    .info-tip {
      display: inline-flex; align-items: center; justify-content: center;
      width: 14px; height: 14px; border-radius: 50%;
      background: transparent; border: 1px solid var(--muted); color: var(--muted);
      font-size: 10px; font-weight: 600; line-height: 1;
      cursor: help; padding: 0; margin-left: 6px;
      vertical-align: middle; transition: all 0.15s;
      position: relative; font-family: inherit;
    }
    .info-tip:hover, .info-tip:focus, .info-tip.open { background: var(--indigo); border-color: var(--indigo); color: white; outline: none; }
    .info-tip .tip-content {
      position: absolute; top: calc(100% + 8px); left: 50%;
      transform: translateX(-50%); min-width: 260px; max-width: 320px;
      background: var(--white); border: 1px solid var(--border); border-radius: 6px;
      padding: 12px; font-size: 13px; line-height: 1.5; color: var(--near-black);
      font-weight: 400; text-align: left; box-shadow: 0 4px 12px rgba(15, 15, 26, 0.08);
      opacity: 0; pointer-events: none; transition: opacity 0.2s ease 0.15s;
      z-index: 1000; white-space: normal; cursor: text;
    }
    .info-tip:hover .tip-content, .info-tip:focus .tip-content, .info-tip.open .tip-content { opacity: 1; pointer-events: auto; }
    .info-tip .tip-content strong { font-weight: 600; color: var(--near-black); }
    .info-tip .tip-content ul { margin: 6px 0; padding-left: 18px; }
    .info-tip .tip-content li { margin: 3px 0; }
    .info-tip .tip-content p { margin: 6px 0; }
    .info-tip .tip-content p:first-child { margin-top: 0; }
    .info-tip .tip-content p:last-child { margin-bottom: 0; }
    .info-tip.up .tip-content { top: auto; bottom: calc(100% + 8px); }
    /* Right-align the content if icon is near right edge of viewport */
    .info-tip.tip-right .tip-content { left: auto; right: -8px; transform: none; }
    .info-tip.tip-left .tip-content { left: -8px; right: auto; transform: none; }

    .badge { display: inline-flex; align-items: center; font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: var(--radius-pill); white-space: nowrap; letter-spacing: 0.02em; }
    /* Segment badges — black with red underline (B), red filled (C), gray outline (Other) */
    .badge-seg-b { background: var(--black); color: var(--white); border-bottom: 2px solid var(--red); border-radius: 4px 4px 0 0; }
    .badge-seg-c { background: var(--red); color: var(--white); }
    .badge-seg-other { background: var(--white); color: var(--text-secondary); border: 1px solid var(--border-strong); }
    /* Contact/outreach badges — Instagram black, Call outlined, Email red */
    .badge-ig { background: var(--black); color: var(--white); position: relative; padding-right: 14px; }
    .badge-ig::after { content: ''; position: absolute; top: 50%; right: 6px; width: 4px; height: 4px; border-radius: 50%; background: var(--red); transform: translateY(-50%); }
    .badge-call { background: var(--white); color: var(--text-primary); border: 1px solid var(--text-primary); }
    .badge-email { background: var(--red); color: var(--white); }
    .badge-none { background: var(--surface); color: var(--text-tertiary); border: 1px solid var(--border); }

    .chip { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 500; padding: 7px 14px; border: 1px solid var(--border); border-radius: var(--radius-pill); background: var(--white); color: var(--text-primary); cursor: pointer; transition: all 0.15s; }
    .chip svg { color: var(--text-primary); flex-shrink: 0; }
    .chip:hover { border-color: var(--indigo); color: var(--indigo); background: var(--lavender); }
    .chip.active { background: var(--red); border-color: var(--red); color: var(--white); }
    .chip.active svg { color: var(--white); }

    .filter-pill { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 500; padding: 5px 10px; border: 1px solid var(--border); border-radius: var(--radius-pill); background: var(--white); color: var(--body); cursor: pointer; transition: all 0.15s; }
    .filter-pill:hover { border-color: var(--border-strong); color: var(--near-black); }
    .filter-pill.active { background: var(--near-black); border-color: var(--near-black); color: white; }
    .filter-pill .count { background: rgba(0,0,0,0.06); color: inherit; padding: 1px 7px; border-radius: 10px; font-size: 11px; font-weight: 600; }
    .filter-pill.active .count { background: rgba(255,255,255,0.2); }

    /* Legacy .channel-toggle removed — filters now live as checkboxes in Advanced */
    /* Channel checkboxes — use accent-color for red tint */
    .channel-check { accent-color: var(--red); width: 15px; height: 15px; cursor: pointer; }
    /* Copy action chips — first-class styling */
    .copy-chip { font-family: inherit; font-size: 13px; font-weight: 500; padding: 6px 12px; border: 1px solid var(--border); border-radius: var(--radius-pill); background: var(--white); color: var(--text-primary); cursor: pointer; transition: all 0.15s; display: inline-flex; align-items: center; gap: 4px; }
    .copy-chip:hover { border-color: var(--red); color: var(--red); background: var(--white); }
    .copy-chip:active { background: var(--red-soft); }
    .copy-chip-count { color: var(--text-tertiary); font-size: 12px; }
    .copy-chip:hover .copy-chip-count { color: var(--red); }

    /* Aggregator warning badge inline in row */
    .aggregator-warn {
      display: inline-flex; align-items: center; justify-content: center;
      width: 18px; height: 18px; border-radius: 4px;
      background: var(--warn-soft); color: var(--warn);
      font-size: 11px; font-weight: 700; cursor: help;
      margin-left: 6px; vertical-align: middle; flex-shrink: 0;
    }

    .priority-hint { display: flex; align-items: flex-start; gap: 12px; padding: 14px 16px; margin-bottom: 20px; background: var(--lavender); border: 1px solid #E0D5FF; border-radius: var(--radius-card); font-size: 13px; color: var(--near-black); position: relative; }
    .priority-hint .hint-ico { width: 28px; height: 28px; border-radius: 8px; background: rgba(86, 100, 239, 0.15); color: var(--indigo); display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .priority-hint .hint-ico svg { width: 14px; height: 14px; }
    .priority-hint .hint-body { flex: 1; padding-top: 4px; line-height: 1.5; }
    .priority-hint .hint-body strong { font-weight: 600; color: var(--indigo); }
    .priority-hint .hint-close { background: none; border: none; color: var(--muted); cursor: pointer; padding: 4px; border-radius: 4px; transition: all 0.15s; position: absolute; top: 10px; right: 10px; }
    .priority-hint .hint-close:hover { background: rgba(0,0,0,0.05); color: var(--near-black); }
    .priority-hint.hidden { display: none; }

    /* ——— Data table ——— */
    .data-table { width: 100%; font-size: 14px; border-collapse: separate; border-spacing: 0; }
    .data-table thead { position: sticky; top: 0; background: var(--section); z-index: 5; }
    .data-table th { text-align: left; padding: 11px 14px; font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid var(--border); user-select: none; }
    .data-table th.sortable { cursor: pointer; }
    .data-table th.sortable:hover { color: var(--near-black); }
    .data-table th.sortable.active { color: var(--indigo); }
    .data-table th .sort-indicator { opacity: 0.35; margin-left: 4px; font-size: 10px; }
    .data-table th.active .sort-indicator { opacity: 1; }
    .data-table td { padding: 12px 14px; font-size: 14px; border-bottom: 1px solid var(--border); vertical-align: middle; color: var(--near-black); }
    .data-table tbody tr { cursor: pointer; transition: background 0.12s; }
    .data-table tbody tr:hover { background: var(--section); }
    .data-table tbody tr.expanded { background: var(--section); }
    .data-table tbody tr.selected { background: rgba(86, 100, 239, 0.06); }
    .data-table .detail-row { background: var(--lavender) !important; }
    .data-table .detail-row:hover { background: var(--lavender) !important; }
    .data-table .detail-row td { padding: 20px 24px; }
    .col-hidden { display: none !important; }

    /* ——— Checkboxes ——— */
    .row-check { width: 16px; height: 16px; accent-color: var(--indigo); cursor: pointer; margin: 0; }

    /* ——— Star button ——— */
    .star-btn { background: none; border: none; cursor: pointer; padding: 4px; border-radius: 4px; color: var(--muted); transition: color 0.15s; }
    .star-btn:hover { color: var(--amber); background: var(--section); }
    .star-btn.saved { color: var(--amber); }
    .star-btn.saved svg { fill: var(--amber); }

    /* ——— Inline contact cell ——— */
    .contact-cell { display: flex; align-items: center; gap: 8px; min-width: 0; }
    .contact-cell .ico-link { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 5px; flex-shrink: 0; text-decoration: none; transition: transform 0.12s; }
    .contact-cell .ico-link svg { width: 14px; height: 14px; }
    .contact-cell .ico-link:hover { transform: scale(1.15); }
    /* Contact icons — Instagram black, Phone outlined-black, Email red */
    .contact-cell .ico-link.ico-ig { color: var(--white); background: var(--black); }
    .contact-cell .ico-link.ico-phone { color: var(--text-primary); background: var(--white); border: 1px solid var(--text-primary); }
    .contact-cell .ico-link.ico-email { color: var(--white); background: var(--red); }
    /* Small amber dot after IG handle when resolved via Google fallback — indicates "please verify" */
    .ig-fallback-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--warn); margin-left: 4px; vertical-align: middle; cursor: help; }
    .contact-cell .value { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--near-black); text-decoration: none; font-size: 13px; font-weight: 500; }
    .contact-cell a.value:hover { color: var(--indigo); text-decoration: underline; }
    .contact-cell .copy-btn { opacity: 0; visibility: hidden; padding: 3px 5px; border: none; background: transparent; color: var(--muted); cursor: pointer; border-radius: 4px; transition: all 0.12s; flex-shrink: 0; }
    .contact-cell .copy-btn svg { width: 12px; height: 12px; display: block; }
    tr:hover .contact-cell .copy-btn { opacity: 1; visibility: visible; }
    .contact-cell .copy-btn:hover { background: var(--section); color: var(--near-black); }
    .contact-cell .copy-btn.copied { color: var(--indigo); opacity: 1; visibility: visible; }
    .empty-dash { color: var(--muted); font-size: 13px; }

    /* ——— Quality pill ——— */
    .quality-pill { display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 22px; border-radius: 11px; font-size: 12px; font-weight: 600; }
    .quality-pill.high { background: var(--black); color: var(--white); }
    .quality-pill.mid { background: var(--amber-soft); color: var(--amber); }
    .quality-pill.low { background: var(--section); color: var(--muted); }

    /* ——— Bulk action bar ——— */
    .bulk-bar { position: fixed; bottom: 20px; left: 50%; transform: translateX(calc(-50% + 118px)); z-index: 50; background: var(--near-black); color: white; border-radius: var(--radius-pill); padding: 6px 8px; box-shadow: var(--shadow-float); display: none; align-items: center; gap: 4px; animation: slideUp 0.2s ease; }
    .bulk-bar.visible { display: inline-flex; }
    @keyframes slideUp { from { opacity: 0; transform: translateX(calc(-50% + 118px)) translateY(12px); } }
    .bulk-count { font-size: 13px; font-weight: 500; padding: 0 14px; white-space: nowrap; }
    .bulk-divider { width: 1px; height: 20px; background: rgba(255,255,255,0.18); margin: 0 2px; }
    .bulk-btn { background: transparent; color: white; border: none; font-family: inherit; font-size: 13px; font-weight: 500; padding: 7px 12px; border-radius: var(--radius-input); cursor: pointer; transition: background 0.12s; display: inline-flex; align-items: center; gap: 6px; white-space: nowrap; }
    .bulk-btn:hover { background: rgba(255,255,255,0.12); }
    .bulk-btn svg { width: 14px; height: 14px; }

    /* ——— Columns menu ——— */
    .col-menu { position: absolute; top: calc(100% + 6px); right: 0; background: var(--white); border: 1px solid var(--border); border-radius: var(--radius-card); box-shadow: var(--shadow-float); padding: 8px; min-width: 200px; z-index: 20; }
    .col-menu.hidden { display: none; }
    .col-menu-title { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); padding: 6px 10px; }
    .col-menu label { display: flex; align-items: center; gap: 8px; padding: 7px 10px; border-radius: 6px; font-size: 13px; color: var(--near-black); cursor: pointer; transition: background 0.1s; }
    .col-menu label:hover { background: var(--section); }
    .col-menu input[type="checkbox"] { accent-color: var(--indigo); margin: 0; }

    /* ——— Toast ——— */
    .toast { position: fixed; bottom: 90px; left: 50%; transform: translateX(-50%); background: var(--near-black); color: white; padding: 10px 18px; border-radius: var(--radius-input); font-size: 13px; font-weight: 500; box-shadow: var(--shadow-float); opacity: 0; pointer-events: none; transition: opacity 0.2s, transform 0.2s; z-index: 100; }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(-4px); }

    .spinner { width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    .stat-card { background: var(--white); border: 1px solid var(--border); border-radius: var(--radius-card); padding: 18px; display: flex; flex-direction: column; }
    .stat-card .stat-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-secondary); margin-bottom: 10px; }
    .stat-card .stat-value { font-size: 32px; font-weight: 500; color: var(--text-primary); line-height: 1; letter-spacing: -0.02em; }
    .stat-card .stat-sub { font-size: 12px; color: var(--text-secondary); margin-top: 6px; line-height: 1.4; }
    .stat-microbar { display: flex; height: 4px; border-radius: 2px; overflow: hidden; background: var(--border); margin-top: 12px; }
    .stat-microbar > div { height: 100%; transition: width 0.3s ease; }
    /* Sticky summary bar — appears once user scrolls past the form */
    .sticky-summary { position: fixed; top: 0; left: 236px; right: 0; background: var(--white); border-bottom: 1px solid var(--border); box-shadow: 0 1px 2px rgba(10,10,10,0.04); z-index: 40; font-size: 13px; opacity: 0; transform: translateY(-100%); transition: opacity 0.18s, transform 0.18s; pointer-events: none; }
    .sticky-summary.visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
    /* Subtle stagger-in for result rows — filter changes feel alive, not janky */
    @keyframes rowFadeIn { from { opacity: 0; transform: translateY(2px); } to { opacity: 1; transform: translateY(0); } }
    .data-table tbody tr { animation: rowFadeIn 0.18s ease both; }
    /* Stat cards ease in on new search */
    @keyframes cardFadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
    .stat-card { animation: cardFadeIn 0.25s ease both; }
    .stat-card .stat-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; margin-bottom: 10px; }
    .stat-card .stat-value { font-size: 28px; font-weight: 700; color: var(--near-black); line-height: 1; letter-spacing: -0.02em; }
    .stat-card .stat-sub { font-size: 12px; color: var(--muted); margin-top: 6px; }
    .mix-bar { display: flex; height: 8px; border-radius: 4px; overflow: hidden; background: var(--border); margin-top: 14px; }
    .mix-seg { height: 100%; transition: width 0.3s; }
    .mix-legend { display: flex; gap: 10px; margin-top: 10px; font-size: 11px; color: var(--muted); flex-wrap: wrap; }
    .mix-legend .dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 5px; vertical-align: middle; }

    .ico-box { width: 40px; height: 40px; border-radius: var(--radius-icon); background: var(--lavender); color: var(--indigo); display: inline-flex; align-items: center; justify-content: center; }
    .ico-box svg { width: 20px; height: 20px; }

    details > summary { list-style: none; cursor: pointer; user-select: none; }
    details > summary::-webkit-details-marker { display: none; }
    details[open] > summary .chev { transform: rotate(90deg); }
    .chev { display: inline-block; transition: transform 0.15s; }

    /* ——— Mobile (≤768px) ——— */
    @media (max-width: 768px) {
      .sidebar { display: none !important; }
      .sticky-summary { left: 0 !important; }
      main { padding: 20px 16px 80px !important; }
      /* Stat cards: stack 2x2 */
      #statsGrid { grid-template-columns: 1fr 1fr !important; gap: 10px !important; }
      /* Form field grids: collapse to single column */
      #searchForm > div > div { grid-template-columns: 1fr !important; gap: 12px !important; }
      /* Results table: allow horizontal scroll rather than shrinking text */
      .data-table-wrap { overflow-x: auto; }
      .data-table { min-width: 900px; }
      /* Filter bar wraps already via flex-wrap — just reduce gaps */
      .filter-pill, .copy-chip { font-size: 12px; padding: 5px 10px; }
    }
    @media (max-width: 480px) {
      #statsGrid { grid-template-columns: 1fr !important; }
    }
  </style>
</head>
<body>
  <div style="display: flex; min-height: 100vh;">
    <aside class="sidebar">
      <div class="brand-lockup">
        <svg class="logo-mark" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="8"/>
          <line x1="12" y1="1" y2="5" x2="12"/>
          <line x1="12" y1="19" y2="23" x2="12"/>
          <line x1="1" y1="12" y2="12" x2="5"/>
          <line x1="19" y1="12" y2="12" x2="23"/>
          <circle cx="12" cy="12" r="2" fill="currentColor"/>
        </svg>
        <span class="logo-wordmark">LeadHunter</span>
      </div>
      <nav class="sidebar-nav">
        <a href="/" class="active"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>Search</a>
        <a href="/history"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>History</a>
        <a href="/leads"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>Saved leads</a>

        <% if (typeof recentSearches !== 'undefined' && recentSearches && recentSearches.length > 0) { %>
          <details class="sidebar-recent" open>
            <summary>Recent searches</summary>
            <% recentSearches.forEach(s => { %>
              <a class="recent-item" href="/history/<%= s.key %>" title="<%= s.keyword %> in <%= s.city %>, <%= s.state %> · <%= s.resultCount %> results">
                <span class="recent-title"><%= s.keyword %></span>
                <span class="recent-meta"><%= s.city %> · <%= s.resultCount %></span>
              </a>
            <% }) %>
          </details>
        <% } %>
      </nav>
      <div class="sidebar-footer">
        <div class="credit-indicator" title="SerpAPI usage this month"><span class="dot"></span>SerpAPI · <%= typeof serpUsage !== 'undefined' ? serpUsage : '—' %></div>
        <div style="font-size: 11px; color: var(--text-tertiary); margin-top: 10px;">Internal tool</div>
      </div>
    </aside>

    <main style="flex: 1; padding: 36px 44px 80px; min-width: 0; max-width: 1800px;">
      <!-- Sticky summary bar — only visible after scrolling past the form (shows current search + jump-back button) -->
      <% if (results && results.length > 0 && query) { %>
      <div class="sticky-summary" id="stickySummary" aria-hidden="true">
        <div style="display: flex; align-items: center; gap: 12px; max-width: 1800px; margin: 0 auto; padding: 10px 44px;">
          <strong style="color: var(--text-primary); font-weight: 600;"><%= query.keyword %></strong>
          <span style="color: var(--text-tertiary);">in <%= query.city %>, <%= query.state %></span>
          <% if (query.ratingMin || query.ratingMax) { %><span style="color: var(--text-tertiary);"> · ★ <%= query.ratingMin || '0' %>–<%= query.ratingMax || '5' %></span><% } %>
          <% if (query.maxResults) { %><span style="color: var(--text-tertiary);"> · <%= query.maxResults %> results</span><% } %>
          <div style="flex: 1;"></div>
          <button type="button" class="btn" style="font-size: 13px; padding: 6px 12px;" onclick="document.getElementById('searchForm').scrollIntoView({behavior:'smooth', block:'start'});">Edit search</button>
        </div>
      </div>
      <% } %>
      <div style="margin-bottom: 28px;">
        <span class="section-label">Prospecting</span>
        <h1 style="font-size: 28px; margin-bottom: 6px;">Find leads</h1>
        <p style="color: var(--text-secondary); font-size: 15px; margin: 0;">Scrape Google Maps across multiple keywords, enrich contact info, and segment by opportunity. Separate multiple keywords with commas to broaden coverage.</p>
      </div>
      <!-- Sentinel for the sticky bar: observe this element; when it leaves the viewport, the sticky bar becomes visible -->
      <div id="stickySentinel" style="height: 1px;"></div>

      <div style="display: flex; flex-wrap: wrap; gap: 8px; align-items: center; margin-bottom: 20px;">
        <span class="ui-label" style="margin-right: 8px;">Vertical</span>
        <button type="button" class="chip" data-preset="cafes">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v2"/><path d="M14 2v2"/><path d="M6 2v2"/><path d="M17 8H3v9a4 4 0 0 0 4 4h7a4 4 0 0 0 4-4Z"/><path d="M16 8a4 4 0 1 1 0 8h-1"/></svg>
          Cafes
        </button>
        <button type="button" class="chip" data-preset="restaurants">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
          Restaurants
        </button>
        <button type="button" class="chip" data-preset="salons">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><path d="M8.12 8.12 12 12"/><path d="M20 4 8.12 15.88"/><circle cx="6" cy="18" r="3"/><path d="M14.8 14.8 20 20"/></svg>
          Salons
        </button>
        <button type="button" class="chip" data-preset="hotels">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></svg>
          Hotels
        </button>
        <button type="button" class="chip" data-preset="dental">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          Dental
        </button>
        <button type="button" class="chip" data-preset="gyms">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6.5 6.5 11 11"/><path d="m21 21-1-1"/><path d="m3 3 1 1"/><path d="m18 22 4-4"/><path d="m2 6 4-4"/><path d="m3 10 7-7"/><path d="m14 21 7-7"/></svg>
          Gyms
        </button>
      </div>

      <form method="GET" action="/search" id="searchForm" class="card" style="padding: 28px; margin-bottom: 20px;">
        <div style="margin-bottom: 20px;">
          <span class="section-label">What to find</span>
          <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 120px; gap: 14px;">
            <div>
              <label class="ui-label" style="display: block; margin-bottom: 6px;">Keyword(s)</label>
              <input class="input" type="text" name="keyword" id="keywordInput" placeholder="cafes, coffee shops, espresso bars" value="<%= query?.keyword || '' %>" required>
              <div class="helper-text">Comma-separate to run multiple searches and dedupe by Google Place ID.</div>
            </div>
            <div>
              <label class="ui-label" style="display: block; margin-bottom: 6px;">City</label>
              <input class="input" type="text" name="city" placeholder="e.g. London" value="<%= query?.city || '' %>" required>
            </div>
            <div>
              <label class="ui-label" style="display: block; margin-bottom: 6px;">Country / State</label>
              <input class="input" type="text" name="state" placeholder="e.g. UK" value="<%= query?.state || '' %>" required>
            </div>
            <div>
              <label class="ui-label" style="display: block; margin-bottom: 6px;">
                Results
                <button type="button" class="info-tip tip-right" aria-label="More info about the Results setting" tabindex="0">?
                  <span class="tip-content" role="tooltip">
                    <p><strong>Results</strong> sets the maximum number of raw businesses fetched from Google Maps.</p>
                    <p>Google Maps returns results in pages of 20. Each page = <strong>1 SerpAPI credit</strong> from your monthly quota.</p>
                    <ul>
                      <li><strong>20</strong> · 1 credit · ~10 sec</li>
                      <li><strong>50</strong> · 3 credits · ~25 sec</li>
                      <li><strong>100</strong> · 5 credits · ~45 sec</li>
                      <li><strong>250</strong> · 13 credits · ~90 sec</li>
                      <li><strong>500</strong> · 25 credits · ~2–3 min</li>
                    </ul>
                    <p>Higher isn't always better — if the market is small, asking for 500 may still return only 40–50 unique businesses after dedupe. Start with 100 for exploration and scale up once you know the market is deep.</p>
                  </span>
                </button>
              </label>
              <select class="select" name="maxResults">
                <% [20,50,100,250,500].forEach(v => { %>
                  <option value="<%= v %>" <%= String(query?.maxResults || 100) == String(v) ? 'selected' : '' %>><%= v %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div style="margin-top: 12px;">
            <label class="ui-label" style="display: block; margin-bottom: 6px;">Exclude <span style="color: var(--muted); font-weight: 500; text-transform: none; letter-spacing: 0;">— optional</span></label>
            <input class="input" type="text" name="excludeKeywords" placeholder="tanning, nail, waxing" value="<%= query?.excludeKeywords || '' %>">
            <div class="helper-text">Any result whose name or category contains one of these terms is filtered out.</div>
          </div>
        </div>

        <div style="border-top: 1px solid var(--border); padding-top: 22px;">
          <span class="section-label">Refine search</span>
          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 18px; align-items: start;">
            <div>
              <label class="ui-label" style="display: flex; align-items: center; margin-bottom: 6px;">Rating range
                <button type="button" class="info-tip" aria-label="More info about Rating range" tabindex="0">?<span class="tip-content" role="tooltip"><p><strong>Rating range</strong> filters businesses by their Google Maps rating.</p><p>4.1–4.7 ★ is the sweet spot for <strong>Segment B</strong>: the business is well-rated but not saturated, so small rating improvements still move the needle.</p><p>Below 4.0 ★ is <strong>Segment C</strong> — reputation recovery territory.</p></span></button>
              </label>
              <div style="display: flex; gap: 6px; align-items: center;">
                <input class="input" type="number" name="ratingMin" step="0.1" min="0" max="5" placeholder="Min" value="<%= query?.ratingMin || '' %>" style="text-align: center;">
                <span style="color: var(--text-tertiary);">–</span>
                <input class="input" type="number" name="ratingMax" step="0.1" min="0" max="5" placeholder="Max" value="<%= query?.ratingMax || '' %>" style="text-align: center;">
              </div>
            </div>
            <div>
              <label class="ui-label" style="display: flex; align-items: center; margin-bottom: 6px;">Max reviews
                <button type="button" class="info-tip" aria-label="More info about Max reviews" tabindex="0">?<span class="tip-content" role="tooltip"><p><strong>Max reviews</strong> caps how much review volume a business can have.</p><p>Lower ceiling means fewer already-exposed businesses — more opportunity to move the needle with new reviews.</p></span></button>
              </label>
              <select class="select" name="maxReviews">
                <option value="">Any</option>
                <% [100,200,300,500,1000].forEach(v => { %>
                  <option value="<%= v %>" <%= String(query?.maxReviews) === String(v) ? 'selected' : '' %>>Under <%= v %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label class="ui-label" style="display: flex; align-items: center; margin-bottom: 6px;">Target segment
                <button type="button" class="info-tip" aria-label="More info about Target segment" tabindex="0">?<span class="tip-content" role="tooltip"><p><strong>Segment B</strong> — 4.1–4.7 ★ &amp; ≤ 300 reviews. Under-exposed, easy upside from more reviews.</p><p><strong>Segment C</strong> — below 4.1 ★ &amp; ≥ 80 reviews. Reputation recovery target.</p><p>Selecting a specific segment pre-filters results server-side so you only see matches.</p></span></button>
              </label>
              <select class="select" name="targetSegment">
                <option value="all" <%= (!query?.targetSegment || query?.targetSegment === 'all') ? 'selected' : '' %>>All candidates</option>
                <option value="B" <%= query?.targetSegment === 'B' ? 'selected' : '' %>>Segment B — good rating, under-reviewed</option>
                <option value="C" <%= query?.targetSegment === 'C' ? 'selected' : '' %>>Segment C — low rating, needs help</option>
                <option value="BC" <%= query?.targetSegment === 'BC' ? 'selected' : '' %>>Both B and C</option>
              </select>
            </div>
          </div>
        </div>

        <details style="margin-top: 20px; border-top: 1px solid var(--border); padding-top: 16px;">
          <summary style="color: var(--text-secondary); font-size: 12px; font-weight: 500;"><span class="chev">▸</span> Advanced</summary>
          <div style="margin-top: 14px;">
            <label class="ui-label" style="display: block; margin-bottom: 8px;">Show leads that have</label>
            <div style="display: flex; gap: 22px; flex-wrap: wrap;">
              <label style="display: inline-flex; align-items: center; gap: 6px; font-size: 13px; color: var(--text-primary); cursor: pointer;">
                <input type="checkbox" class="channel-check" data-channel="email" checked> Email <span class="ch-count" id="cntEmail" style="color: var(--text-tertiary); font-size: 12px;">0</span>
              </label>
              <label style="display: inline-flex; align-items: center; gap: 6px; font-size: 13px; color: var(--text-primary); cursor: pointer;">
                <input type="checkbox" class="channel-check" data-channel="phone" checked> Contact number <span class="ch-count" id="cntPhone" style="color: var(--text-tertiary); font-size: 12px;">0</span>
              </label>
              <label style="display: inline-flex; align-items: center; gap: 6px; font-size: 13px; color: var(--text-primary); cursor: pointer;">
                <input type="checkbox" class="channel-check" data-channel="instagram" checked> Instagram <span class="ch-count" id="cntInstagram" style="color: var(--text-tertiary); font-size: 12px;">0</span>
              </label>
            </div>
            <div class="helper-text">Show leads that have at least one of the selected contact methods.</div>
          </div>
          <div style="margin-top: 14px; display: flex; align-items: center; gap: 10px;">
            <input type="checkbox" name="skipEnrichment" id="skipEnrichment" <%= query?.skipEnrichment === 'on' ? 'checked' : '' %>>
            <label for="skipEnrichment" style="font-size: 13px; color: var(--text-primary);">Skip enrichment — faster, returns listings without email/phone/Instagram</label>
          </div>
          <div style="margin-top: 10px; display: flex; align-items: flex-start; gap: 10px;">
            <input type="checkbox" name="useIgFallback" id="useIgFallback" value="on" <%= (!query || query?.useIgFallback !== 'off') ? 'checked' : '' %> style="margin-top: 3px;">
            <label for="useIgFallback" style="font-size: 13px; color: var(--body); line-height: 1.5;">
              Use Google to find Instagram handles when the business website doesn't have one. Uses extra SerpAPI credits.
            </label>
          </div>
        </details>

        <div style="margin-top: 24px; display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
          <button type="submit" class="btn btn-primary" id="searchBtn" style="min-width: 200px;">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <span id="searchBtnText">Find leads</span>
          </button>
          <span style="font-size: 12px; color: var(--muted);" id="searchHint">Contact enrichment (email, phone, Instagram) is on by default.</span>
        </div>
      </form>

      <div class="priority-hint hidden" id="priorityHint">
        <span class="hint-ico"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg></span>
        <div class="hint-body" id="hintBody"></div>
        <button class="hint-close" onclick="dismissHint()" aria-label="Dismiss hint"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
      </div>

      <% if (error) { %>
        <div class="card" style="padding: 14px 18px; border-color: var(--red); background: var(--red-soft); color: var(--red); margin-bottom: 20px;"><%= error %></div>
      <% } %>

      <% if (results && results.length > 0) { %>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 20px;" id="statsGrid"></div>

        <div class="card" style="padding: 16px 18px; margin-bottom: 12px;">
          <div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: center; margin-bottom: 12px;">
            <span class="ui-label" style="margin-right: 4px;">Segment</span>
            <button class="filter-pill active" data-filter="segment" data-value="all" type="button">All <span class="count" id="cntSegAll">0</span></button>
            <button class="filter-pill" data-filter="segment" data-value="B" type="button">B <span class="count" id="cntSegB">0</span></button>
            <button class="filter-pill" data-filter="segment" data-value="C" type="button">C <span class="count" id="cntSegC">0</span></button>
            <button class="filter-pill" data-filter="segment" data-value="-" type="button">Other <span class="count" id="cntSegOther">0</span></button>
            <span style="width: 1px; height: 24px; background: var(--border); margin: 0 8px;"></span>
            <button class="filter-pill" data-filter="saved" data-value="true" type="button">⭐ Saved only</button>
            <div style="flex: 1;"></div>
            <input class="input" id="textFilter" placeholder="Filter by name..." style="width: 220px; padding: 7px 12px; font-size: 13px;">
            <div style="position: relative;">
              <button type="button" class="btn" id="columnsBtn" style="font-size: 13px; padding: 7px 12px;">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
                Columns
              </button>
              <div class="col-menu hidden" id="columnsMenu">
                <div class="col-menu-title">Optional columns</div>
                <label><input type="checkbox" data-col="outreach"> Outreach primary</label>
                <label><input type="checkbox" data-col="booking"> Booking platform</label>
                <label><input type="checkbox" data-col="hours"> Hours</label>
                <label><input type="checkbox" data-col="price"> Price tier</label>
              </div>
            </div>
          </div>
          <div style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap; padding-top: 12px; border-top: 1px solid var(--border);">
            <span class="ui-label" style="margin-right: 4px;">Copy filtered</span>
            <button type="button" class="copy-chip" id="copyIG">Instagram handles <span id="cntCopyIG" class="copy-chip-count">(0)</span></button>
            <button type="button" class="copy-chip" id="copyEmails">Emails <span id="cntCopyEmail" class="copy-chip-count">(0)</span></button>
            <button type="button" class="copy-chip" id="copyPhones">Phones <span id="cntCopyPhone" class="copy-chip-count">(0)</span></button>
            <div style="flex: 1;"></div>
            <button type="button" class="btn" id="exportJSON" style="font-size: 13px; padding: 7px 12px;">JSON</button>
            <button type="button" class="btn" id="exportCSV" style="font-size: 13px; padding: 7px 12px;">CSV</button>
          </div>
        </div>

        <div style="display: flex; align-items: center; justify-content: space-between; margin: 0 4px 10px;">
          <div style="color: var(--body); font-size: 13px;">
            Showing <span style="color: var(--near-black); font-weight: 600;" id="visibleCount"><%= results.length %></span>
            <% if (totalScraped > results.length) { %><span style="color: var(--muted);"> · deduped from <%= totalScraped %> scraped</span><% } %>
            <% if (query?.searchString) { %><span style="color: var(--muted);"> · "<%= query.searchString %>"</span><% } %>
          </div>
        </div>

        <div class="card" style="overflow: hidden; padding: 0;">
          <div style="max-height: calc(100vh - 520px); overflow: auto;">
            <table class="data-table" id="resultsTable">
              <thead>
                <tr>
                  <th style="width: 40px;"><input type="checkbox" id="selectAllCheck" class="row-check" title="Select all visible" aria-label="Select all visible"></th>
                  <th style="width: 40px;"></th>
                  <th class="sortable" data-sort="title">Name <span class="sort-indicator">↕</span></th>
                  <th class="sortable" data-sort="rating" style="width: 80px;">Rating <span class="sort-indicator">↕</span></th>
                  <th class="sortable" data-sort="reviewCount" style="width: 80px; text-align: right;">Reviews <span class="sort-indicator">↕</span></th>
                  <th class="sortable" data-sort="segmentCode" style="width: 104px;">Segment <span class="sort-indicator">↕</span></th>
                  <th class="sortable col-outreach col-hidden" data-sort="outreach" style="width: 100px;">Outreach <span class="sort-indicator">↕</span></th>
                  <th class="sortable" data-sort="instagram" style="width: 160px;">Instagram <span class="sort-indicator">↕</span></th>
                  <th class="sortable" data-sort="phone" style="width: 160px;">Phone <span class="sort-indicator">↕</span></th>
                  <th class="sortable" data-sort="email" style="width: 220px;">Email <span class="sort-indicator">↕</span></th>
                  <th class="col-booking col-hidden" style="width: 140px;">Booking</th>
                  <th class="col-hours col-hidden" style="width: 120px;">Hours</th>
                  <th class="col-price col-hidden" style="width: 70px;">Price</th>
                  <th class="sortable" data-sort="qualityScore" style="width: 76px; text-align: center;">Quality <span class="sort-indicator">↕</span></th>
                  <th style="width: 52px;">Maps</th>
                </tr>
              </thead>
              <tbody id="resultsBody"></tbody>
            </table>
          </div>
        </div>
      <% } else if (results && results.length === 0) { %>
        <div class="card" style="padding: 48px 24px; text-align: center;">
          <div class="ico-box" style="margin: 0 auto 16px;"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg></div>
          <h2 style="font-size: 18px; margin-bottom: 6px; font-weight: 600;">No businesses matched your search.</h2>
          <p style="color: var(--text-secondary); margin: 0 0 18px;">Widen your filters or try broader keywords.</p>
          <div style="display: flex; gap: 8px; justify-content: center; margin-bottom: 20px;">
            <button type="button" class="btn btn-primary" onclick="widenFilters()">Widen filters</button>
            <button type="button" class="btn" onclick="resetFilters()">Reset filters</button>
          </div>
          <ul style="list-style: none; padding: 0; margin: 0; color: var(--text-tertiary); font-size: 13px; display: flex; flex-direction: column; gap: 4px; align-items: center;">
            <li>• Try a wider rating range</li>
            <li>• Increase the max reviews limit</li>
            <li>• Try a broader or adjacent keyword</li>
          </ul>
        </div>
      <% } else if (!error) { %>
        <div class="card" style="padding: 56px 24px; text-align: center;">
          <div class="ico-box" style="margin: 0 auto 18px;"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div>
          <h2 style="font-size: 20px; margin-bottom: 8px;">Pick a vertical to start</h2>
          <p style="color: var(--body); margin-bottom: 22px;">Or try one of these:</p>
          <div style="display: flex; gap: 8px; justify-content: center; flex-wrap: wrap;">
            <button type="button" class="chip suggestion-chip" data-keyword="cafes, coffee shops, espresso bars" data-city="Shoreditch" data-state="UK">London cafes</button>
            <button type="button" class="chip suggestion-chip" data-keyword="restaurants, bistros" data-city="Manchester" data-state="UK">Manchester restaurants</button>
            <button type="button" class="chip suggestion-chip" data-keyword="hair salons, barbershops" data-city="Birmingham" data-state="UK">Birmingham salons</button>
            <button type="button" class="chip suggestion-chip" data-keyword="dental clinic" data-city="Leeds" data-state="UK">Leeds dental clinics</button>
          </div>
        </div>
      <% } %>
    </main>
  </div>

  <!-- Bulk action bar -->
  <div class="bulk-bar" id="bulkBar">
    <span class="bulk-count"><span id="bulkCountNum">0</span> selected</span>
    <div class="bulk-divider"></div>
    <button type="button" class="bulk-btn" id="bulkCopyEmails"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>Copy emails</button>
    <button type="button" class="bulk-btn" id="bulkCopyPhones"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>Copy phones</button>
    <button type="button" class="bulk-btn" id="bulkCopyIG"><svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>Copy Instagram</button>
    <button type="button" class="bulk-btn" id="bulkSave">⭐ Save all</button>
    <button type="button" class="bulk-btn" id="bulkExportCSV">Export CSV</button>
    <div class="bulk-divider"></div>
    <button type="button" class="bulk-btn" id="bulkClear">Clear</button>
  </div>

  <div class="toast" id="toast"></div>

  <script>
    const allResults = <%- JSON.stringify(results || []) %>;
    let savedLeads = {};
    const state = {
      channels: { email: true, phone: true, instagram: true },
      filters: { segment: 'all', saved: false, text: '' },
      sort: { key: null, dir: 'asc' },
      expanded: new Set(),
      selected: new Set()
    };

    // ——— Presets ———
    const PRESETS = {
      cafes:       { keyword: 'cafes, coffee shops, espresso bars', ratingMin: 4.1, ratingMax: 4.7, maxReviews: '300' },
      restaurants: { keyword: 'restaurants, bistros, eateries',     ratingMin: 4.0, ratingMax: 4.6, maxReviews: '500' },
      salons:      { keyword: 'hair salons, barbershops',           ratingMin: 4.1, ratingMax: 4.8, maxReviews: '200' },
      hotels:      { keyword: 'hotels, boutique hotels',            ratingMin: 3.8, ratingMax: 4.5, maxReviews: '1000' },
      dental:      { keyword: 'dental clinic, dentist',             ratingMin: 4.0, ratingMax: 4.9, maxReviews: '500' },
      gyms:        { keyword: 'gyms, fitness studios',              ratingMin: 4.0, ratingMax: 4.7, maxReviews: '300' }
    };
    document.querySelectorAll('[data-preset]').forEach(b => b.addEventListener('click', () => {
      const p = PRESETS[b.dataset.preset];
      document.querySelector('[name=keyword]').value = p.keyword;
      document.querySelector('[name=ratingMin]').value = p.ratingMin;
      document.querySelector('[name=ratingMax]').value = p.ratingMax;
      document.querySelector('[name=maxReviews]').value = p.maxReviews;
      document.querySelectorAll('[data-preset]').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
      document.querySelector('[name=keyword]').focus();
      refreshPriorityHint();
    }));
    document.querySelectorAll('.suggestion-chip').forEach(b => b.addEventListener('click', () => {
      document.querySelector('[name=keyword]').value = b.dataset.keyword;
      document.querySelector('[name=city]').value = b.dataset.city;
      document.querySelector('[name=state]').value = b.dataset.state;
      document.querySelector('#searchForm').scrollIntoView({ behavior: 'smooth', block: 'center' });
      refreshPriorityHint();
    }));

    // ——— Priority hint ———
    const VERTICAL_MAP = [
      { words: ['salon', 'nail', 'barber', 'spa', 'beauty', 'hair'], key: 'beauty',
        text: '<strong>Recommended priority for this vertical:</strong> Instagram → Phone → Email. Toggle off Email to focus on the highest-intent channels first.' },
      { words: ['restaurant', 'hotel', 'bar', 'pub', 'cafe', 'café', 'coffee', 'bistro', 'eatery'], key: 'hospitality',
        text: '<strong>Recommended priority for this vertical:</strong> Phone → Instagram → Email. Restaurants and hotels typically answer phone calls during service hours.' },
      { words: ['dental', 'legal', 'accountant', 'lawyer', 'clinic', 'doctor', 'solicitor', 'attorney'], key: 'professional',
        text: '<strong>Recommended priority for this vertical:</strong> Email → Phone → Instagram. Professional services are more formal and respond better to email.' }
    ];
    let hintState = { lastKey: null, dismissed: false };
    function detectVertical(keyword) {
      const kw = (keyword || '').toLowerCase();
      if (!kw) return null;
      return VERTICAL_MAP.find(v => v.words.some(w => kw.includes(w))) || null;
    }
    function refreshPriorityHint() {
      const hint = document.getElementById('priorityHint');
      const body = document.getElementById('hintBody');
      if (!hint || !body) return;
      const kw = document.querySelector('[name=keyword]')?.value || '';
      const match = detectVertical(kw);
      if (!match) { hint.classList.add('hidden'); hintState.lastKey = null; return; }
      if (hintState.lastKey !== match.key) { hintState.dismissed = false; hintState.lastKey = match.key; }
      if (hintState.dismissed) { hint.classList.add('hidden'); return; }
      body.innerHTML = match.text;
      hint.classList.remove('hidden');
    }
    window.dismissHint = () => { hintState.dismissed = true; document.getElementById('priorityHint').classList.add('hidden'); };
    document.getElementById('keywordInput')?.addEventListener('input', refreshPriorityHint);

    // ——— Persistence ———
    const LS_KEY = 'leadmapper:prefs';
    const loadPrefs = () => { try { return JSON.parse(localStorage.getItem(LS_KEY) || '{}'); } catch { return {}; } };
    const savePrefs = (p) => localStorage.setItem(LS_KEY, JSON.stringify({ ...loadPrefs(), ...p }));
    (function restorePrefs() {
      const prefs = loadPrefs();
      if (!<%= !!query ? 'true' : 'false' %>) {
        const set = (name, val) => { const el = document.querySelector(`[name=${name}]`); if (el && val) el.value = val; };
        set('keyword', prefs.keyword); set('city', prefs.city); set('state', prefs.state);
        set('excludeKeywords', prefs.excludeKeywords);
        set('ratingMin', prefs.ratingMin); set('ratingMax', prefs.ratingMax);
        set('maxReviews', prefs.maxReviews); set('maxResults', prefs.maxResults);
        set('targetSegment', prefs.targetSegment);
        // Restore IG fallback checkbox (default ON if never set)
        const igCb = document.getElementById('useIgFallback');
        if (igCb && prefs.useIgFallback === 'off') igCb.checked = false;
      }
      // Restore column visibility
      const cols = (prefs.columns || {});
      ['outreach', 'booking', 'hours', 'price'].forEach(col => {
        const visible = !!cols[col];
        document.querySelectorAll(`.col-${col}`).forEach(el => el.classList.toggle('col-hidden', !visible));
        const cb = document.querySelector(`[data-col="${col}"]`);
        if (cb) cb.checked = visible;
      });
      refreshPriorityHint();
    })();

    document.getElementById('searchForm').addEventListener('submit', function(e) {
      const fd = new FormData(e.target);
      savePrefs({
        keyword: fd.get('keyword'), excludeKeywords: fd.get('excludeKeywords'),
        city: fd.get('city'), state: fd.get('state'),
        ratingMin: fd.get('ratingMin'), ratingMax: fd.get('ratingMax'),
        maxReviews: fd.get('maxReviews'), maxResults: fd.get('maxResults'),
        targetSegment: fd.get('targetSegment'),
        useIgFallback: fd.get('useIgFallback') ? 'on' : 'off'
      });
      const btn = document.getElementById('searchBtn');
      btn.disabled = true;
      const kwCount = (fd.get('keyword') || '').split(',').map(k => k.trim()).filter(Boolean).length;
      document.getElementById('searchBtnText').innerHTML = `<span class="spinner" style="margin-right: 6px;"></span>${kwCount > 1 ? `Running ${kwCount} keyword searches...` : 'Scraping & enriching...'}`;
      document.getElementById('searchHint').textContent = `Takes ${Math.max(1, kwCount)}–${Math.max(4, kwCount * 3)} minutes depending on result count.`;
    });

    fetch('/leads/saved').then(r => r.json()).then(leads => {
      leads.forEach(l => { savedLeads[l.title] = l.key; });
      render();
    }).catch(() => render());

    // ——— Stats ———
    function renderStats() {
      const grid = document.getElementById('statsGrid');
      if (!grid) return;
      const total = allResults.length;
      const totalScraped = <%= totalScraped || 0 %>;
      const enriched = allResults.filter(r => r.email || r.phone || r.instagram).length;
      const enrichRate = total ? Math.round((enriched / total) * 100) : 0;
      const igFromSite = allResults.filter(r => r.instagram && r.instagramSource === 'website').length;
      const igFromMaps = allResults.filter(r => r.instagram && r.instagramSource === 'maps').length;
      const igFromFallback = allResults.filter(r => r.instagram && r.instagramSource === 'google_fallback').length;
      const segB = allResults.filter(r => r.segmentCode === 'B').length;
      const segC = allResults.filter(r => r.segmentCode === 'C').length;
      const avgQuality = total ? Math.round(allResults.reduce((s, r) => s + (r.qualityScore || 0), 0) / total) : 0;
      const ig = allResults.filter(r => r.outreach === 'DM').length;
      const call = allResults.filter(r => r.outreach === 'Call').length;
      const email = allResults.filter(r => r.outreach === 'Email').length;
      const none = allResults.filter(r => r.outreach === 'None').length;
      const pct = (n) => total ? Math.round((n / total) * 100) : 0;
      // Every card has: LABEL · big number · sub-line · optional micro-bar (4px)
      const segTotal = segB + segC;
      const bPct = segTotal ? (segB / segTotal) * 100 : 0;
      const cPct = segTotal ? (segC / segTotal) * 100 : 0;
      grid.innerHTML = `
        <div class="stat-card">
          <div class="stat-label" style="display: flex; align-items: center;">
            Total leads
            <button type="button" class="info-tip" aria-label="More info about Total leads" tabindex="0">?<span class="tip-content" role="tooltip"><p><strong>Total leads</strong> is the number of unique businesses that matched your search after filters.</p><p>Google Maps returned <strong>${totalScraped} raw results</strong> across your keyword(s); after removing duplicates and applying filters, <strong>${total}</strong> remain.</p><p>A high raw-to-final ratio means you've hit the market's natural ceiling for this combination — widen filters or try adjacent keywords to find more.</p></span></button>
          </div>
          <div class="stat-value">${total}</div>
          <div class="stat-sub">businesses matched your filters</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Segmented</div>
          <div class="stat-value">${segTotal}</div>
          <div class="stat-sub">${segB} in Segment B · ${segC} in Segment C</div>
          <div class="stat-microbar" title="Segment B (black) vs Segment C (red)"><div style="width: ${bPct}%; background: var(--black);"></div><div style="width: ${cPct}%; background: var(--red);"></div></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Outreach mix</div>
          <div class="stat-value">${enriched}</div>
          <div class="stat-sub">leads with contact info · ${enrichRate}% enriched</div>
          <div class="stat-microbar"><div style="width: ${pct(ig)}%; background: var(--black);"></div><div style="width: ${pct(call)}%; background: var(--red);"></div><div style="width: ${pct(email)}%; background: repeating-linear-gradient(45deg, var(--red-soft), var(--red-soft) 3px, var(--white) 3px, var(--white) 6px); border-top: 1px solid var(--red); border-bottom: 1px solid var(--red); box-sizing: border-box;"></div><div style="width: ${pct(none)}%; background: var(--border);"></div></div>
          <div class="mix-legend" style="margin-top: 8px;">
            <span><span class="dot" style="background: var(--black);"></span>IG ${pct(ig)}%</span>
            <span><span class="dot" style="background: var(--red);"></span>Call ${pct(call)}%</span>
            <span><span class="dot" style="background: var(--white); border: 1px solid var(--red);"></span>Email ${pct(email)}%</span>
            <span><span class="dot" style="background: var(--border);"></span>None ${pct(none)}%</span>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Avg quality</div>
          <div class="stat-value">${avgQuality}</div>
          <div class="stat-sub">${enrichRate}% enrichment rate${igFromFallback > 0 ? ` · <span title="Of ${igFromSite + igFromMaps + igFromFallback} Instagram handles: ${igFromSite} from website, ${igFromMaps} from Maps, ${igFromFallback} from Google fallback (please verify these).">${igFromFallback} IG via Google fallback</span>` : ''}</div>
          <div class="stat-microbar"><div style="width: ${Math.min(avgQuality, 100)}%; background: var(--red);"></div></div>
        </div>
      `;
    }

    function updateFilterCounts() {
      if (!document.getElementById('cntEmail')) return;
      document.getElementById('cntEmail').textContent = allResults.filter(r => r.email).length;
      document.getElementById('cntPhone').textContent = allResults.filter(r => r.phone).length;
      document.getElementById('cntInstagram').textContent = allResults.filter(r => r.instagram).length;
      document.getElementById('cntSegAll').textContent = allResults.length;
      document.getElementById('cntSegB').textContent = allResults.filter(r => r.segmentCode === 'B').length;
      document.getElementById('cntSegC').textContent = allResults.filter(r => r.segmentCode === 'C').length;
      document.getElementById('cntSegOther').textContent = allResults.filter(r => r.segmentCode === '-').length;
    }

    function passesChannels(r) {
      const { email, phone, instagram } = state.channels;
      if (!email && !phone && !instagram) return false;
      if (email && r.email) return true;
      if (phone && r.phone) return true;
      if (instagram && r.instagram) return true;
      return false;
    }

    function applyFilters() {
      const { segment, saved, text } = state.filters;
      const q = text.trim().toLowerCase();
      let rows = allResults.filter(r => {
        if (!passesChannels(r)) return false;
        if (segment !== 'all' && r.segmentCode !== segment) return false;
        if (saved && !savedLeads[r.title]) return false;
        if (q && !r.title.toLowerCase().includes(q)) return false;
        return true;
      });
      if (state.sort.key) {
        rows = rows.slice().sort((a, b) => {
          let va = a[state.sort.key], vb = b[state.sort.key];
          if (va == null) va = '';
          if (vb == null) vb = '';
          if (typeof va === 'string') { va = va.toLowerCase(); vb = String(vb).toLowerCase(); }
          if (va < vb) return state.sort.dir === 'asc' ? -1 : 1;
          if (va > vb) return state.sort.dir === 'asc' ? 1 : -1;
          return 0;
        });
      }
      return rows;
    }

    const escapeHTML = s => (s || '').toString().replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    const escapeAttr = s => escapeHTML(s).replace(/"/g, '&quot;');

    function igUrl(handle) {
      if (!handle) return '';
      if (/^https?:\/\//i.test(handle)) return handle;
      const h = handle.replace(/^[@\/]+/, '');
      return 'https://instagram.com/' + h;
    }
    function igHandle(handle) { return (handle || '').replace(/^[@\/]+/, ''); }

    const badgeSegment = c => c === 'B'
      ? '<span class="badge badge-seg-b" title="Segment B: good rating (4.1–4.7 ★) with ≤300 reviews. Under-exposed — easy upside from more reviews.">Segment B</span>'
      : c === 'C'
      ? '<span class="badge badge-seg-c" title="Segment C: rating below 4.1 ★ with ≥80 reviews. Reputation recovery target.">Segment C</span>'
      : '<span class="badge badge-seg-other" title="Not a target segment — either rating too high, too few reviews, or between B and C thresholds.">Other</span>';
    const badgeOutreach = o => o === 'DM' ? '<span class="badge badge-ig">Instagram</span>' : o === 'Call' ? '<span class="badge badge-call">Call</span>' : o === 'Email' ? '<span class="badge badge-email">Email</span>' : '<span class="badge badge-none">None</span>';
    function qualityPill(score) {
      const s = typeof score === 'number' ? score : 0;
      const cls = s >= 70 ? 'high' : s >= 40 ? 'mid' : 'low';
      return `<div class="quality-pill ${cls}" title="Quality score ${s}/100">${s}</div>`;
    }

    const ICO_COPY = `<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15V5a2 2 0 012-2h10"/></svg>`;
    const ICO_IG = `<svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`;
    const ICO_PHONE = `<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>`;
    const ICO_EMAIL = `<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`;

    function contactCellIG(r) {
      if (!r.instagram) return '<span class="empty-dash">—</span>';
      const h = igHandle(r.instagram);
      const url = igUrl(r.instagram);
      const isFallback = r.instagramSource === 'google_fallback';
      const icoTitle = isFallback
        ? 'Instagram found via Google search — verify before outreach.'
        : 'Open Instagram';
      const valueTitle = isFallback
        ? `@${h} (resolved via Google fallback — please verify)`
        : `@${h}`;
      const fallbackMark = isFallback
        ? `<span class="ig-fallback-dot" title="Resolved via Google fallback — please verify before outreach" aria-label="Resolved via Google fallback"></span>`
        : '';
      return `<div class="contact-cell">
        <a href="${escapeAttr(url)}" target="_blank" rel="noopener" onclick="event.stopPropagation()" class="ico-link ico-ig" title="${escapeAttr(icoTitle)}">${ICO_IG}</a>
        <a href="${escapeAttr(url)}" target="_blank" rel="noopener" onclick="event.stopPropagation()" class="value" title="${escapeAttr(valueTitle)}">@${escapeHTML(h)}${fallbackMark}</a>
        <button type="button" class="copy-btn" onclick="event.stopPropagation(); copyValue(this, '${escapeAttr(h)}')" title="Copy handle">${ICO_COPY}</button>
      </div>`;
    }
    function contactCellPhone(r) {
      if (!r.phone) return '<span class="empty-dash">—</span>';
      const p = r.phone;
      return `<div class="contact-cell">
        <a href="tel:${escapeAttr(p)}" onclick="event.stopPropagation()" class="ico-link ico-phone" title="Call">${ICO_PHONE}</a>
        <a href="tel:${escapeAttr(p)}" onclick="event.stopPropagation()" class="value" title="${escapeAttr(p)}">${escapeHTML(p)}</a>
        <button type="button" class="copy-btn" onclick="event.stopPropagation(); copyValue(this, '${escapeAttr(p)}')" title="Copy number">${ICO_COPY}</button>
      </div>`;
    }
    function contactCellEmail(r) {
      if (!r.email) return '<span class="empty-dash">—</span>';
      const e = r.email;
      return `<div class="contact-cell">
        <a href="mailto:${escapeAttr(e)}" onclick="event.stopPropagation()" class="ico-link ico-email" title="Compose email">${ICO_EMAIL}</a>
        <a href="mailto:${escapeAttr(e)}" onclick="event.stopPropagation()" class="value" title="${escapeAttr(e)}">${escapeHTML(e)}</a>
        <button type="button" class="copy-btn" onclick="event.stopPropagation(); copyValue(this, '${escapeAttr(e)}')" title="Copy email">${ICO_COPY}</button>
      </div>`;
    }

    function renderRows() {
      const rows = applyFilters();
      document.getElementById('visibleCount').textContent = rows.length;
      document.getElementById('cntCopyIG').textContent = '(' + rows.filter(r => r.instagram).length + ')';
      document.getElementById('cntCopyEmail').textContent = '(' + rows.filter(r => r.email).length + ')';
      document.getElementById('cntCopyPhone').textContent = '(' + rows.filter(r => r.phone).length + ')';

      const body = document.getElementById('resultsBody');
      body.innerHTML = '';
      // Invalidate stale selections (row filtered out)
      const visibleIdxs = new Set(rows.map(r => allResults.indexOf(r)));
      for (const idx of state.selected) if (!visibleIdxs.has(idx)) state.selected.delete(idx);

      if (rows.length === 0) {
        body.innerHTML = `<tr><td colspan="16" style="padding: 36px; text-align: center; color: var(--muted);">No rows match these filters. <button class="btn btn-ghost" onclick="clearAllFilters()" style="font-size: 13px; margin-left: 6px;">Clear filters</button></td></tr>`;
        updateBulkBar();
        return;
      }
      rows.forEach(r => {
        const origIdx = allResults.indexOf(r);
        const isSaved = !!savedLeads[r.title];
        const isSelected = state.selected.has(origIdx);
        const tr = document.createElement('tr');
        tr.dataset.idx = origIdx;
        if (isSelected) tr.classList.add('selected');
        tr.innerHTML = `
          <td onclick="event.stopPropagation()"><input type="checkbox" class="row-check" data-idx="${origIdx}" ${isSelected ? 'checked' : ''}></td>
          <td onclick="event.stopPropagation(); toggleSave(${origIdx})">
            <button class="star-btn ${isSaved ? 'saved' : ''}" title="${isSaved ? 'Unsave' : 'Save lead'}">
              <svg width="18" height="18" fill="${isSaved ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
            </button>
          </td>
          <td>
            <div style="font-weight: 500; color: var(--near-black); display: flex; align-items: center;">
              <span>${escapeHTML(r.title)}</span>
              ${r.isAggregator ? `<span class="aggregator-warn" title="This business's listed website is a third-party platform (e.g. Talabat, Yelp, OpenTable). Contact info may be incomplete — verify the Instagram and phone before outreach.">⚠</span>` : ''}
            </div>
            <div style="font-size: 12px; color: var(--muted); margin-top: 2px;">${escapeHTML(r.category)}${r.address ? ' · ' + escapeHTML(r.address) : ''}</div>
          </td>
          <td>${r.rating != null ? `<span style="color: var(--amber); font-weight: 500;">★ ${r.rating}</span>` : '<span class="empty-dash">—</span>'}</td>
          <td style="text-align: right; color: var(--body);">${r.reviewCount != null ? r.reviewCount : '—'}</td>
          <td>${badgeSegment(r.segmentCode)}</td>
          <td class="col-outreach col-hidden">${badgeOutreach(r.outreach)}</td>
          <td>${contactCellIG(r)}</td>
          <td>${contactCellPhone(r)}</td>
          <td>${contactCellEmail(r)}</td>
          <td class="col-booking col-hidden"><span style="font-size: 12px; color: var(--body);">${r.booking ? escapeHTML(r.booking) : '<span class="empty-dash">—</span>'}</span></td>
          <td class="col-hours col-hidden"><span style="font-size: 12px; color: var(--body);">${r.hours ? escapeHTML(r.hours) : '<span class="empty-dash">—</span>'}</span></td>
          <td class="col-price col-hidden"><span style="font-weight: 600; color: var(--near-black);">${r.priceTier ? escapeHTML(r.priceTier) : '<span class="empty-dash">—</span>'}</span></td>
          <td style="text-align: center;">${qualityPill(r.qualityScore)}</td>
          <td>${r.url ? `<a href="${escapeAttr(r.url)}" target="_blank" onclick="event.stopPropagation()" style="display: inline-flex; width: 24px; height: 24px; align-items: center; justify-content: center; border-radius: 5px; color: var(--muted);" title="Open in Google Maps"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></a>` : ''}</td>
        `;
        tr.addEventListener('click', () => toggleExpand(origIdx));
        body.appendChild(tr);
        if (state.expanded.has(origIdx)) {
          tr.classList.add('expanded');
          body.appendChild(buildDetailRow(r));
        }
      });
      // Re-apply hidden column classes (in case prefs had toggles)
      applyColumnVisibility();
      // Wire checkboxes
      body.querySelectorAll('.row-check').forEach(cb => {
        cb.addEventListener('change', (e) => {
          const idx = parseInt(e.target.dataset.idx, 10);
          if (e.target.checked) state.selected.add(idx); else state.selected.delete(idx);
          const row = e.target.closest('tr');
          if (row) row.classList.toggle('selected', e.target.checked);
          updateBulkBar();
        });
      });
      // Select-all checkbox state
      const selectAll = document.getElementById('selectAllCheck');
      if (selectAll) {
        const allSelected = rows.length > 0 && rows.every(r => state.selected.has(allResults.indexOf(r)));
        selectAll.checked = allSelected;
        selectAll.indeterminate = !allSelected && rows.some(r => state.selected.has(allResults.indexOf(r)));
      }
      updateBulkBar();
    }

    function applyColumnVisibility() {
      const prefs = loadPrefs();
      const cols = prefs.columns || {};
      ['outreach', 'booking', 'hours', 'price'].forEach(col => {
        const visible = !!cols[col];
        document.querySelectorAll(`.col-${col}`).forEach(el => el.classList.toggle('col-hidden', !visible));
      });
    }

    function buildDetailRow(r) {
      const tr = document.createElement('tr');
      tr.className = 'detail-row';
      tr.innerHTML = `
        <td colspan="16">
          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px;">
            <div>
              <div class="ui-label" style="margin-bottom: 8px;">Contact</div>
              ${r.phone ? `<div style="margin-bottom: 6px;"><span class="caption">Phone · </span><a href="tel:${escapeAttr(r.phone)}">${escapeHTML(r.phone)}</a></div>` : ''}
              ${r.email ? `<div style="margin-bottom: 6px;"><span class="caption">Email · </span><a href="mailto:${escapeAttr(r.email)}">${escapeHTML(r.email)}</a></div>` : ''}
              ${r.instagram ? `<div style="margin-bottom: 6px;"><span class="caption">Instagram · </span><a href="${escapeAttr(igUrl(r.instagram))}" target="_blank" rel="noopener" style="color: var(--black); font-weight: 500;">@${escapeHTML(igHandle(r.instagram))}</a></div>` : ''}
              ${r.isAggregator ? `<div style="margin-top: 10px; padding: 8px 10px; background: var(--warn-soft); border-radius: 6px; font-size: 12px; color: var(--warn);"><strong>⚠ Listed website is a third-party platform.</strong> Contact info may be incomplete — verify Instagram and phone before outreach.</div>` : ''}
              ${!r.phone && !r.email && !r.instagram ? `<div class="caption">No contact info found.</div>` : ''}
            </div>
            <div>
              <div class="ui-label" style="margin-bottom: 8px;">Details</div>
              ${r.website ? `<div style="margin-bottom: 6px;"><span class="caption">Website · </span><a href="${escapeAttr(r.website)}" target="_blank">${escapeHTML(r.website.replace(/https?:\/\/(www\.)?/, '').split('/')[0])}</a></div>` : ''}
              ${r.booking ? `<div style="margin-bottom: 6px;"><span class="caption">Booking · </span>${escapeHTML(r.booking)}</div>` : ''}
              ${r.hours ? `<div style="margin-bottom: 6px;"><span class="caption">Hours · </span>${escapeHTML(r.hours)}</div>` : ''}
              ${r.priceTier ? `<div style="margin-bottom: 6px;"><span class="caption">Price · </span>${escapeHTML(r.priceTier)}</div>` : ''}
              ${r.address ? `<div style="margin-bottom: 6px; color: var(--body); font-size: 13px;">${escapeHTML(r.address)}</div>` : ''}
              ${r.category ? `<div class="caption">${escapeHTML(r.category)}</div>` : ''}
            </div>
            <div>
              <div class="ui-label" style="margin-bottom: 8px;">Quick actions</div>
              <div style="display: flex; flex-direction: column; gap: 8px;">
                ${r.url ? `<a href="${escapeAttr(r.url)}" target="_blank" class="btn" style="font-size: 13px;">Open in Google Maps</a>` : ''}
                ${r.website ? `<a href="${escapeAttr(r.website)}" target="_blank" class="btn" style="font-size: 13px;">Visit website</a>` : ''}
                <div style="font-size: 12px; color: var(--muted); margin-top: 6px;">Data quality: ${qualityPill(r.qualityScore)}</div>
              </div>
            </div>
          </div>
        </td>
      `;
      return tr;
    }

    function toggleExpand(idx) {
      if (state.expanded.has(idx)) state.expanded.delete(idx);
      else state.expanded.add(idx);
      renderRows();
    }

    async function toggleSave(idx) {
      const lead = allResults[idx];
      if (savedLeads[lead.title]) {
        await fetch(`/leads/delete/${savedLeads[lead.title]}`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        delete savedLeads[lead.title];
        showToast('Removed from saved');
      } else {
        const res = await fetch('/leads/save', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(lead) });
        const data = await res.json();
        savedLeads[lead.title] = data.key;
        showToast('Lead saved');
      }
      render();
    }
    window.toggleSave = toggleSave;

    // ——— Channel checkboxes (in Advanced form section) ———
    document.querySelectorAll('.channel-check').forEach(cb => cb.addEventListener('change', () => {
      const ch = cb.dataset.channel;
      state.channels[ch] = cb.checked;
      renderRows();
    }));

    // ——— Filter pills ———
    document.querySelectorAll('.filter-pill').forEach(p => p.addEventListener('click', () => {
      const f = p.dataset.filter, v = p.dataset.value;
      if (f === 'saved') {
        state.filters.saved = !state.filters.saved;
        p.classList.toggle('active', state.filters.saved);
      } else {
        state.filters[f] = v;
        document.querySelectorAll(`[data-filter="${f}"]`).forEach(x => x.classList.remove('active'));
        p.classList.add('active');
      }
      renderRows();
    }));
    let textTimer = null;
    document.getElementById('textFilter')?.addEventListener('input', (e) => {
      clearTimeout(textTimer);
      textTimer = setTimeout(() => { state.filters.text = e.target.value; renderRows(); }, 200);
    });
    window.clearAllFilters = () => {
      state.channels = { email: true, phone: true, instagram: true };
      state.filters = { segment: 'all', saved: false, text: '' };
      const tf = document.getElementById('textFilter'); if (tf) tf.value = '';
      document.querySelectorAll('.channel-check').forEach(cb => cb.checked = true);
      document.querySelectorAll('.filter-pill').forEach(p => {
        p.classList.toggle('active', p.dataset.value === 'all' && p.dataset.filter !== 'saved');
        if (p.dataset.filter === 'saved') p.classList.remove('active');
      });
      renderRows();
    };
    // Empty-state CTA handlers
    window.widenFilters = () => {
      // Scroll to the form and focus the rating range
      document.getElementById('searchForm')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      setTimeout(() => document.querySelector('[name="ratingMin"]')?.focus(), 400);
    };
    window.resetFilters = () => {
      const f = document.getElementById('searchForm');
      if (!f) return;
      // Clear all filter-like fields, keep keyword/city/state so it re-runs the same search with wider params
      f.querySelector('[name=ratingMin]').value = '';
      f.querySelector('[name=ratingMax]').value = '';
      f.querySelector('[name=maxReviews]').value = '';
      f.querySelector('[name=targetSegment]').value = 'all';
      f.querySelector('[name=excludeKeywords]').value = '';
      f.submit();
    };

    // ——— Sorting ———
    document.querySelectorAll('th.sortable').forEach(th => th.addEventListener('click', () => {
      const key = th.dataset.sort;
      if (state.sort.key === key) state.sort.dir = state.sort.dir === 'asc' ? 'desc' : 'asc';
      else { state.sort.key = key; state.sort.dir = 'asc'; }
      document.querySelectorAll('th.sortable').forEach(x => {
        x.classList.toggle('active', x.dataset.sort === state.sort.key);
        const ind = x.querySelector('.sort-indicator');
        if (x.dataset.sort === state.sort.key) ind.textContent = state.sort.dir === 'asc' ? '↑' : '↓';
        else ind.textContent = '↕';
      });
      renderRows();
    }));

    // ——— Select-all checkbox ———
    document.getElementById('selectAllCheck')?.addEventListener('change', (e) => {
      const rows = applyFilters();
      if (e.target.checked) rows.forEach(r => state.selected.add(allResults.indexOf(r)));
      else rows.forEach(r => state.selected.delete(allResults.indexOf(r)));
      renderRows();
    });

    // ——— Columns menu ———
    document.getElementById('columnsBtn')?.addEventListener('click', (e) => {
      e.stopPropagation();
      document.getElementById('columnsMenu').classList.toggle('hidden');
    });
    document.addEventListener('click', (e) => {
      const m = document.getElementById('columnsMenu');
      if (m && !m.classList.contains('hidden') && !m.contains(e.target) && e.target.id !== 'columnsBtn') m.classList.add('hidden');
    });
    document.querySelectorAll('[data-col]').forEach(cb => cb.addEventListener('change', (e) => {
      const col = cb.dataset.col;
      const visible = cb.checked;
      document.querySelectorAll(`.col-${col}`).forEach(el => el.classList.toggle('col-hidden', !visible));
      const prefs = loadPrefs();
      prefs.columns = prefs.columns || {};
      prefs.columns[col] = visible;
      savePrefs(prefs);
    }));

    // ——— Bulk action bar ———
    function updateBulkBar() {
      const bar = document.getElementById('bulkBar');
      const count = state.selected.size;
      if (count > 0) { bar.classList.add('visible'); document.getElementById('bulkCountNum').textContent = count; }
      else bar.classList.remove('visible');
    }
    function selectedLeads() { return [...state.selected].map(i => allResults[i]).filter(Boolean); }
    document.getElementById('bulkCopyEmails')?.addEventListener('click', () => {
      const list = selectedLeads().filter(r => r.email).map(r => r.email);
      if (!list.length) return showToast('No emails in selection');
      navigator.clipboard.writeText(list.join('\n')).then(() => showToast(`Copied ${list.length} emails`));
    });
    document.getElementById('bulkCopyPhones')?.addEventListener('click', () => {
      const list = selectedLeads().filter(r => r.phone).map(r => r.phone);
      if (!list.length) return showToast('No phones in selection');
      navigator.clipboard.writeText(list.join('\n')).then(() => showToast(`Copied ${list.length} phones`));
    });
    document.getElementById('bulkCopyIG')?.addEventListener('click', () => {
      const list = selectedLeads().filter(r => r.instagram).map(r => igHandle(r.instagram));
      if (!list.length) return showToast('No Instagram handles in selection');
      navigator.clipboard.writeText(list.join('\n')).then(() => showToast(`Copied ${list.length} handles`));
    });
    document.getElementById('bulkSave')?.addEventListener('click', async () => {
      const sel = selectedLeads();
      let saved = 0;
      for (const lead of sel) {
        if (savedLeads[lead.title]) continue;
        const res = await fetch('/leads/save', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(lead) });
        const data = await res.json();
        savedLeads[lead.title] = data.key;
        saved++;
      }
      showToast(`Saved ${saved} new · ${sel.length - saved} already saved`);
      render();
    });
    document.getElementById('bulkExportCSV')?.addEventListener('click', () => {
      const sel = selectedLeads();
      if (!sel.length) return showToast('Nothing selected');
      exportCSV(sel, `leadhunter-selected-${Date.now()}.csv`);
    });
    document.getElementById('bulkClear')?.addEventListener('click', () => {
      state.selected.clear();
      renderRows();
    });

    // ——— Toast & copy ———
    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg; t.classList.add('show');
      clearTimeout(showToast._t);
      showToast._t = setTimeout(() => t.classList.remove('show'), 1600);
    }
    function copyValue(btn, value) {
      navigator.clipboard.writeText(value).then(() => {
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 900);
        showToast('Copied');
      });
    }
    window.copyValue = copyValue;
    function copyList(items, emptyMsg, successMsg) {
      if (!items.length) { showToast(emptyMsg); return; }
      navigator.clipboard.writeText(items.join('\n')).then(() => showToast(`${successMsg} (${items.length})`));
    }
    document.getElementById('copyIG')?.addEventListener('click', () => {
      const rows = applyFilters();
      copyList(rows.filter(r => r.instagram).map(r => igHandle(r.instagram)), 'No Instagram handles in current filter', 'Handles copied');
    });
    document.getElementById('copyEmails')?.addEventListener('click', () => {
      const rows = applyFilters();
      copyList(rows.filter(r => r.email).map(r => r.email), 'No emails in current filter', 'Emails copied');
    });
    document.getElementById('copyPhones')?.addEventListener('click', () => {
      const rows = applyFilters();
      copyList(rows.filter(r => r.phone).map(r => r.phone), 'No phones in current filter', 'Phones copied');
    });
    function exportCSV(rows, filename) {
      const headers = ['Name','Phone','Email','Instagram','Booking','Hours','PriceTier','Website','Category','Address','Rating','Reviews','Segment','Outreach','QualityScore','Google Maps URL'];
      const csvRows = rows.map(r => [
        r.title, r.phone, r.email, r.instagram || '', r.booking || '', r.hours || '', r.priceTier || '',
        r.website, r.category, r.address, r.rating, r.reviewCount, r.segment || '', r.outreach || '', r.qualityScore || '', r.url
      ].map(v => `"${(v || '').toString().replace(/"/g, '""')}"`).join(','));
      const csv = [headers.join(','), ...csvRows].join('\n');
      downloadBlob(csv, 'text/csv', filename || `leadhunter-${Date.now()}.csv`);
    }
    function downloadBlob(content, type, name) {
      const blob = new Blob([content], { type });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = name;
      a.click();
    }
    document.getElementById('exportCSV')?.addEventListener('click', () => {
      const rows = applyFilters();
      if (!rows.length) return showToast('No rows to export');
      exportCSV(rows);
      showToast(`Exported ${rows.length} rows`);
    });
    document.getElementById('exportJSON')?.addEventListener('click', () => {
      const rows = applyFilters();
      if (!rows.length) return showToast('No rows to export');
      downloadBlob(JSON.stringify(rows, null, 2), 'application/json', `leadhunter-${Date.now()}.json`);
      showToast(`Exported ${rows.length} rows as JSON`);
    });

    function render() { renderStats(); updateFilterCounts(); renderRows(); }
    render();

    // Sticky summary bar — fire when the sentinel (just below the heading) leaves the viewport
    (function wireStickySummary() {
      const bar = document.getElementById('stickySummary');
      const sentinel = document.getElementById('stickySentinel');
      if (!bar || !sentinel || !('IntersectionObserver' in window)) return;
      const io = new IntersectionObserver(entries => {
        for (const e of entries) bar.classList.toggle('visible', !e.isIntersecting);
      }, { threshold: 0 });
      io.observe(sentinel);
    })();

    // ——— Info tooltips: tap (mobile), keyboard (Enter/Space toggles, Escape closes), viewport-flip ———
    function wireInfoTips(root) {
      const tips = (root || document).querySelectorAll('.info-tip');
      tips.forEach(tip => {
        if (tip.dataset.wired) return;
        tip.dataset.wired = '1';
        tip.addEventListener('click', e => {
          e.stopPropagation();
          // Close others
          document.querySelectorAll('.info-tip.open').forEach(t => { if (t !== tip) t.classList.remove('open'); });
          tip.classList.toggle('open');
          positionTip(tip);
        });
        tip.addEventListener('keydown', e => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            tip.classList.toggle('open');
            positionTip(tip);
          } else if (e.key === 'Escape') {
            tip.classList.remove('open');
            tip.blur();
          }
        });
        tip.addEventListener('mouseenter', () => positionTip(tip));
        tip.addEventListener('focus', () => positionTip(tip));
      });
    }
    function positionTip(tip) {
      // Flip up if bottom would overflow
      const content = tip.querySelector('.tip-content');
      if (!content) return;
      // Reset class state
      tip.classList.remove('up');
      requestAnimationFrame(() => {
        const rect = content.getBoundingClientRect();
        if (rect.bottom > window.innerHeight - 8) tip.classList.add('up');
      });
    }
    // Close open tooltips when clicking outside
    document.addEventListener('click', () => {
      document.querySelectorAll('.info-tip.open').forEach(t => t.classList.remove('open'));
    });
    // Wire existing tips + re-wire after any re-render (stats re-renders on refresh)
    wireInfoTips();
    const origRender = render;
    render = function() { origRender(); wireInfoTips(); };
  </script>
</body>
</html>
