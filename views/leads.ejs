<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Saved leads — LeadMapper · Starise</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --indigo: #5664EF; --indigo-hover: #4450DB; --purple: #9D57F5;
      --brand-gradient: linear-gradient(135deg, #5664EF 0%, #9D57F5 100%);
      --near-black: #0F0F1A; --body: #4A4A4A; --muted: #6B6B80;
      --border: #E8E8F0; --border-strong: #D4D4E0;
      --lavender: #F3EEFF; --section: #F9FAFD; --white: #FFFFFF;
      --radius-card: 16px; --radius-input: 8px;
      --shadow-soft: 0 1px 2px rgba(15, 15, 26, 0.04);
      --shadow-cta: 0 4px 12px rgba(86, 100, 239, 0.2);
      --red: #DC2626; --red-soft: #FEF2F2; --amber: #D97706;
      --pink: #DB2777; --pink-soft: #FDF2F8;
      --sky: #0284C7; --sky-soft: #F0F9FF;
      --teal: #0D9488; --teal-soft: #F0FDFA;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body { font-family: 'Inter', -apple-system, sans-serif; background: var(--section); color: var(--body); font-size: 14px; line-height: 1.5; -webkit-font-smoothing: antialiased; }
    h1 { color: var(--near-black); font-weight: 700; letter-spacing: -0.01em; margin: 0; }
    a { color: var(--indigo); text-decoration: none; }
    a:hover { color: var(--indigo-hover); }
    .section-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--indigo); margin-bottom: 12px; display: block; }
    .card { background: var(--white); border: 1px solid var(--border); border-radius: var(--radius-card); box-shadow: var(--shadow-soft); }
    .btn { font-family: inherit; font-size: 14px; font-weight: 500; padding: 10px 16px; border-radius: var(--radius-input); border: 1px solid var(--border); background: var(--white); color: var(--near-black); cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 6px; transition: all 0.15s; }
    .btn:hover { background: var(--section); border-color: var(--border-strong); }
    .btn-primary { background: var(--brand-gradient); border: none; color: white; border-radius: 9999px; box-shadow: var(--shadow-cta); font-weight: 600; padding: 12px 24px; }
    .sidebar { background: var(--white); border-right: 1px solid var(--border); width: 236px; flex-shrink: 0; display: flex; flex-direction: column; height: 100vh; position: sticky; top: 0; }
    .brand-lockup { display: flex; align-items: center; gap: 10px; padding: 22px 20px 18px; border-bottom: 1px solid var(--border); }
    .logo-starise { display: inline-flex; align-items: center; gap: 6px; font-weight: 500; font-size: 15px; color: var(--indigo); letter-spacing: 0.22em; text-transform: lowercase; }
    .brand-lockup .divider { color: var(--border-strong); font-size: 14px; margin: 0 2px; }
    .brand-lockup .product { font-size: 13px; font-weight: 500; color: var(--near-black); letter-spacing: -0.01em; }
    .sidebar-nav { padding: 12px 8px; flex: 1; }
    .sidebar-nav a { display: flex; align-items: center; gap: 10px; padding: 9px 12px; margin: 2px 0; border-radius: var(--radius-input); font-size: 14px; font-weight: 500; color: var(--body); text-decoration: none; position: relative; }
    .sidebar-nav a:hover { background: var(--section); color: var(--near-black); }
    .sidebar-nav a.active { background: var(--lavender); color: var(--indigo); }
    .sidebar-nav a.active::before { content: ''; position: absolute; left: -8px; top: 8px; bottom: 8px; width: 3px; background: var(--indigo); border-radius: 2px; }
    .sidebar-nav a svg { width: 18px; height: 18px; }
    .sidebar-footer { padding: 16px; border-top: 1px solid var(--border); }
    .badge { display: inline-flex; align-items: center; font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 9999px; }
    .badge-dm { background: var(--pink-soft); color: var(--pink); }
    .badge-call { background: var(--sky-soft); color: var(--sky); }
    .badge-email { background: var(--teal-soft); color: var(--teal); }
    .data-table { width: 100%; font-size: 14px; border-collapse: separate; border-spacing: 0; }
    .data-table th { text-align: left; padding: 11px 14px; font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid var(--border); background: var(--section); }
    .data-table td { padding: 14px; border-bottom: 1px solid var(--border); color: var(--near-black); vertical-align: middle; }
    .data-table tbody tr:hover { background: var(--section); }
    .ico-box { width: 40px; height: 40px; border-radius: 12px; background: var(--lavender); color: var(--indigo); display: inline-flex; align-items: center; justify-content: center; }
    .del-btn { background: none; border: none; color: var(--muted); cursor: pointer; padding: 6px; border-radius: 6px; transition: all 0.15s; }
    .del-btn:hover { background: var(--red-soft); color: var(--red); }
  </style>
</head>
<body>
  <div style="display: flex; min-height: 100vh;">
    <aside class="sidebar">
      <div class="brand-lockup">
        <span class="logo-starise">starise<svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" style="margin-left: 2px; margin-top: -8px;"><path d="M12 0 L13.3 10.7 L24 12 L13.3 13.3 L12 24 L10.7 13.3 L0 12 L10.7 10.7 Z"/></svg></span>
        <span class="divider">·</span>
        <span class="product">LeadMapper</span>
      </div>
      <nav class="sidebar-nav">
        <a href="/"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>Search</a>
        <a href="/history"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>History</a>
        <a href="/leads" class="active"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>Saved leads</a>
      </nav>
      <div class="sidebar-footer">
        <div style="font-size: 11px; color: var(--muted);">Internal tool · Starise</div>
      </div>
    </aside>

    <main style="flex: 1; padding: 36px 44px; min-width: 0; max-width: 1600px;">
      <div style="margin-bottom: 24px;">
        <span class="section-label">Prospecting</span>
        <h1 style="font-size: 28px; margin-bottom: 6px;">Saved leads <span style="color: var(--muted); font-weight: 500;" id="leadCount">(<%= leads.length %>)</span></h1>
        <p style="color: var(--body); font-size: 15px;">Your starred leads from across searches. Click a row to see full details.</p>
      </div>

      <% if (leads.length === 0) { %>
        <div class="card" style="padding: 56px 24px; text-align: center;">
          <div class="ico-box" style="margin: 0 auto 18px;"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg></div>
          <h2 style="font-size: 18px; margin: 0 0 6px; color: var(--near-black);">No saved leads yet</h2>
          <p style="color: var(--body); margin: 0 0 20px;">Star a lead from any search result to add it here.</p>
          <a href="/" class="btn btn-primary">Start searching</a>
        </div>
      <% } else { %>
        <div class="card" style="overflow: hidden; padding: 0;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Name</th>
                <th style="width: 140px;">Phone</th>
                <th style="width: 160px;">Email</th>
                <th style="width: 140px;">Instagram</th>
                <th style="width: 180px;">Website</th>
                <th style="width: 90px;">Rating</th>
                <th style="width: 100px;">Saved</th>
                <th style="width: 60px;"></th>
              </tr>
            </thead>
            <tbody id="leadsBody">
              <% leads.forEach(l => { %>
              <tr data-key="<%= l.key %>">
                <td>
                  <div style="font-weight: 500;"><%= l.title %></div>
                  <% if (l.category) { %><div style="font-size: 12px; color: var(--muted); margin-top: 2px;"><%= l.category %></div><% } %>
                </td>
                <td style="color: var(--body);"><%= l.phone || '—' %></td>
                <td>
                  <% if (l.email) { %><a href="mailto:<%= l.email %>" style="font-size: 13px;"><%= l.email %></a><% } else { %><span style="color: var(--muted);">—</span><% } %>
                </td>
                <td>
                  <% if (l.instagram) { %><a href="https://instagram.com/<%= l.instagram %>" target="_blank" style="color: var(--pink); font-size: 13px;">@<%= l.instagram %></a><% } else { %><span style="color: var(--muted);">—</span><% } %>
                </td>
                <td>
                  <% if (l.website) { %><a href="<%= l.website %>" target="_blank" style="font-size: 13px;"><%= l.website.replace(/https?:\/\/(www\.)?/, '').split('/')[0] %></a><% } else { %>—<% } %>
                </td>
                <td>
                  <% if (l.rating != null) { %><span style="color: var(--amber); font-weight: 500;">★ <%= l.rating %></span><% } else { %>—<% } %>
                </td>
                <td style="color: var(--muted); font-size: 13px;"><%= new Date(l.savedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) %></td>
                <td>
                  <button class="del-btn" onclick="removeLead('<%= l.key %>', this)" title="Remove from saved">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </main>
  </div>

  <script>
    async function removeLead(key, btn) {
      if (!confirm('Remove this lead?')) return;
      await fetch(`/leads/delete/${key}`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
      btn.closest('tr').remove();
      const remaining = document.querySelectorAll('#leadsBody tr').length;
      document.getElementById('leadCount').textContent = `(${remaining})`;
      if (remaining === 0) location.reload();
    }
  </script>
</body>
</html>
