<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>History — LeadHunter</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --red: #E11D2E; --red-hover: #B8161E; --red-active: #8B1015;
      --black: #0A0A0A; --white: #FFFFFF;
      --surface: #FAFAFA; --border: #EAEAEA; --border-strong: #D4D4D4;
      --text-primary: #0A0A0A; --text-secondary: #6B6B6B; --text-tertiary: #9A9A9A;
      --radius-card: 8px; --radius-input: 6px;
      --shadow-soft: 0 1px 2px rgba(10, 10, 10, 0.04);
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body { font-family: 'Inter', -apple-system, sans-serif; background: var(--surface); color: var(--text-primary); font-size: 14px; line-height: 1.5; -webkit-font-smoothing: antialiased; }
    h1 { color: var(--text-primary); font-weight: 600; letter-spacing: -0.01em; margin: 0; }
    a { color: var(--red); text-decoration: none; }
    a:hover { color: var(--red-hover); }
    .section-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-secondary); margin-bottom: 10px; display: block; }
    .card { background: var(--white); border: 1px solid var(--border); border-radius: var(--radius-card); box-shadow: var(--shadow-soft); }
    .btn { font-family: inherit; font-size: 14px; font-weight: 500; padding: 10px 16px; border-radius: var(--radius-input); border: 1px solid var(--border); background: var(--white); color: var(--text-primary); cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 6px; transition: all 0.15s; }
    .btn:hover { background: var(--surface); border-color: var(--border-strong); }
    .btn-primary { background: var(--red); border: 1px solid var(--red); color: var(--white); font-weight: 500; padding: 10px 18px; }
    .btn-primary:hover { background: var(--red-hover); border-color: var(--red-hover); }
    .sidebar { background: var(--white); border-right: 1px solid var(--border); width: 236px; flex-shrink: 0; display: flex; flex-direction: column; height: 100vh; position: sticky; top: 0; }
    .brand-lockup { display: flex; align-items: center; gap: 8px; padding: 22px 20px 18px; border-bottom: 1px solid var(--border); }
    .logo-mark { color: var(--black); flex-shrink: 0; }
    .logo-wordmark { font-family: 'Inter', sans-serif; font-weight: 600; font-size: 18px; color: var(--black); letter-spacing: -0.01em; }
    .sidebar-nav { padding: 12px 8px; flex: 1; }
    .sidebar-nav a { display: flex; align-items: center; gap: 10px; padding: 9px 12px; margin: 2px 0; border-radius: var(--radius-input); font-size: 14px; font-weight: 500; color: var(--text-secondary); text-decoration: none; position: relative; }
    .sidebar-nav a:hover { background: var(--surface); color: var(--text-primary); }
    .sidebar-nav a.active { background: var(--surface); color: var(--text-primary); }
    .sidebar-nav a.active::before { content: ''; position: absolute; left: -8px; top: 8px; bottom: 8px; width: 3px; background: var(--red); border-radius: 2px; }
    .sidebar-nav a svg { width: 18px; height: 18px; flex-shrink: 0; }
    .sidebar-footer { padding: 16px; border-top: 1px solid var(--border); }
    .badge-count { display: inline-flex; align-items: center; font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 9999px; background: var(--black); color: var(--white); }
    .data-table { width: 100%; font-size: 14px; border-collapse: separate; border-spacing: 0; }
    .data-table th { text-align: left; padding: 11px 14px; font-size: 11px; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid var(--border); background: var(--surface); }
    .data-table td { padding: 14px; border-bottom: 1px solid var(--border); color: var(--text-primary); }
    .data-table tbody tr:hover { background: var(--surface); }
    .ico-box { width: 40px; height: 40px; border-radius: 8px; background: var(--surface); color: var(--black); display: inline-flex; align-items: center; justify-content: center; border: 1px solid var(--border); }
  </style>
</head>
<body>
  <div style="display: flex; min-height: 100vh;">
    <aside class="sidebar">
      <div class="brand-lockup">
        <svg class="logo-mark" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="8"/>
          <line x1="12" y1="1" y2="5" x2="12"/>
          <line x1="12" y1="19" y2="23" x2="12"/>
          <line x1="1" y1="12" y2="12" x2="5"/>
          <line x1="19" y1="12" y2="12" x2="23"/>
          <circle cx="12" cy="12" r="2" fill="currentColor"/>
        </svg>
        <span class="logo-wordmark">LeadHunter</span>
      </div>
      <nav class="sidebar-nav">
        <a href="/"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>Search</a>
        <a href="/history" class="active"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>History</a>
        <a href="/leads"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>Saved leads</a>
      </nav>
      <div class="sidebar-footer">
        <div style="font-size: 11px; color: var(--text-tertiary);">Internal tool</div>
      </div>
    </aside>

    <main style="flex: 1; padding: 36px 44px; min-width: 0; max-width: 1400px;">
      <div style="margin-bottom: 24px;">
        <span class="section-label">Prospecting</span>
        <h1 style="font-size: 28px; margin-bottom: 6px;">Search history</h1>
        <p style="color: var(--text-secondary); font-size: 15px; margin: 0;">Every search you've run, with filters and result counts. Click a row to re-open the results.</p>
      </div>

      <% if (searches.length === 0) { %>
        <div class="card" style="padding: 56px 24px; text-align: center;">
          <div class="ico-box" style="margin: 0 auto 18px;"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
          <h2 style="font-size: 18px; margin: 0 0 6px; color: var(--text-primary); font-weight: 600;">No searches yet</h2>
          <p style="color: var(--text-secondary); margin: 0 0 20px;">Your searches will appear here.</p>
          <a href="/" class="btn btn-primary">Start searching</a>
        </div>
      <% } else { %>
        <div class="card" style="overflow: hidden; padding: 0;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Keyword</th>
                <th>Location</th>
                <th style="text-align: center; width: 100px;">Results</th>
                <th style="width: 180px;">Date</th>
                <th style="text-align: right; width: 160px;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% searches.forEach(s => { %>
              <tr>
                <td style="font-weight: 500;"><%= s.keyword %></td>
                <td style="color: var(--text-secondary);"><%= s.city %>, <%= s.state %></td>
                <td style="text-align: center;"><span class="badge-count"><%= s.resultCount %></span></td>
                <td style="color: var(--text-tertiary); font-size: 13px;"><%= new Date(s.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></td>
                <td style="text-align: right;">
                  <a href="/history/<%= s.key %>" style="margin-right: 14px; font-size: 13px; font-weight: 500;">View</a>
                  <form method="POST" action="/history/delete/<%= s.key %>" style="display: inline;" onsubmit="return confirm('Delete this search?')">
                    <button type="submit" style="background: none; border: none; color: var(--red); font-size: 13px; font-weight: 500; cursor: pointer; font-family: inherit;">Delete</button>
                  </form>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </main>
  </div>
</body>
</html>
